---
import type { Lang } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const copy = {
  fr: {
    kicker: 'Essaie, sans installer',
    title: 'Trois questions. Trois secondes de réflexion.',
    subtitle: 'Quel est le drapeau, la capitale, ou l\'animal ? C\'est la vraie mécanique de SAPIRO, directement dans ton navigateur.',
    start: 'Commencer',
    next: 'Question suivante',
    restart: 'Rejouer',
    download: 'Installer l\'app pour 2 000+ questions',
    correct: 'Bien joué !',
    wrong: 'Presque…',
    score: 'Ton score',
    of: 'sur',
    explanation: 'Explication',
    question: 'Question',
  },
  en: {
    kicker: 'Try it, no install',
    title: 'Three questions. Three seconds to think.',
    subtitle: 'Which flag, which capital, which animal? This is the real SAPIRO mechanic, right in your browser.',
    start: 'Start',
    next: 'Next question',
    restart: 'Play again',
    download: 'Install the app for 2,000+ questions',
    correct: 'Nice!',
    wrong: 'Almost…',
    score: 'Your score',
    of: 'of',
    explanation: 'Explanation',
    question: 'Question',
  },
  es: {
    kicker: 'Prueba, sin instalar',
    title: 'Tres preguntas. Tres segundos para pensar.',
    subtitle: 'Que bandera, que capital, que animal? Asi funciona SAPIRO, directamente en tu navegador.',
    start: 'Empezar',
    next: 'Siguiente pregunta',
    restart: 'Jugar otra vez',
    download: 'Instalar la app para 2 000+ preguntas',
    correct: 'Bien jugado !',
    wrong: 'Casi…',
    score: 'Tu puntuacion',
    of: 'de',
    explanation: 'Explicacion',
    question: 'Pregunta',
  },
};

const questions = {
  fr: [
    {
      visual: '🇯🇵',
      prompt: 'À quel pays appartient ce drapeau ?',
      options: ['Corée du Sud', 'Japon', 'Chine', 'Vietnam'],
      answer: 1,
      explanation: 'Le drapeau japonais, appelé Hinomaru, représente le soleil levant sur fond blanc. Adopté officiellement en 1999.',
    },
    {
      visual: '🏛️',
      prompt: 'Quelle est la capitale de l\'Australie ?',
      options: ['Sydney', 'Melbourne', 'Canberra', 'Perth'],
      answer: 2,
      explanation: 'Canberra a été choisie comme capitale en 1908 pour résoudre la rivalité entre Sydney et Melbourne.',
    },
    {
      visual: '🦓',
      prompt: 'Sur quel continent vit le zèbre à l\'état sauvage ?',
      options: ['Asie', 'Amérique du Sud', 'Afrique', 'Océanie'],
      answer: 2,
      explanation: 'Les trois espèces de zèbres (commun, de Grévy, des montagnes) vivent toutes en Afrique.',
    },
  ],
  en: [
    {
      visual: '🇯🇵',
      prompt: 'Which country does this flag belong to?',
      options: ['South Korea', 'Japan', 'China', 'Vietnam'],
      answer: 1,
      explanation: 'The Japanese flag, called Hinomaru, shows the rising sun on a white background. Officially adopted in 1999.',
    },
    {
      visual: '🏛️',
      prompt: 'What is the capital of Australia?',
      options: ['Sydney', 'Melbourne', 'Canberra', 'Perth'],
      answer: 2,
      explanation: 'Canberra was chosen as the capital in 1908 to settle the rivalry between Sydney and Melbourne.',
    },
    {
      visual: '🦓',
      prompt: 'On which continent do zebras live in the wild?',
      options: ['Asia', 'South America', 'Africa', 'Oceania'],
      answer: 2,
      explanation: 'All three zebra species (plains, Grevy\'s, mountain) live in Africa.',
    },
  ],
  es: [
    {
      visual: '🇯🇵',
      prompt: 'A que pais pertenece esta bandera?',
      options: ['Corea del Sur', 'Japon', 'China', 'Vietnam'],
      answer: 1,
      explanation: 'La bandera japonesa, llamada Hinomaru, muestra el sol naciente sobre fondo blanco. Adoptada oficialmente en 1999.',
    },
    {
      visual: '🏛️',
      prompt: 'Cual es la capital de Australia?',
      options: ['Sydney', 'Melbourne', 'Canberra', 'Perth'],
      answer: 2,
      explanation: 'Canberra fue elegida capital en 1908 para resolver la rivalidad entre Sydney y Melbourne.',
    },
    {
      visual: '🦓',
      prompt: 'En que continente vive la cebra en estado salvaje?',
      options: ['Asia', 'America del Sur', 'Africa', 'Oceania'],
      answer: 2,
      explanation: 'Las tres especies de cebras (comun, de Grevy, de montana) viven todas en Africa.',
    },
  ],
};

const t = copy[lang];
const qs = questions[lang];
---

<section class="demo-quiz" id="demo-quiz">
  <div class="container">
    <div class="header-block">
      <span class="kicker">⚡ {t.kicker}</span>
      <h2 class="title">{t.title}</h2>
      <p class="subtitle">{t.subtitle}</p>
    </div>

    <div class="quiz-card" id="quiz-card" data-lang={lang}>
      <!-- Progress bar -->
      <div class="progress">
        <div class="progress-fill" id="progress-fill"></div>
      </div>

      <!-- Intro screen -->
      <div class="screen screen-intro active" data-screen="intro">
        <div class="intro-visual">🎯</div>
        <h3 class="screen-title">3 questions, 30 secondes</h3>
        <p class="screen-sub">{t.subtitle}</p>
        <button class="btn-quiz btn-quiz-primary" data-action="start">
          {t.start}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>

      <!-- Question screens -->
      {qs.map((q, idx) => (
        <div class="screen screen-question" data-screen={`q-${idx}`} data-answer={q.answer}>
          <div class="question-meta">
            <span class="question-num">{t.question} {idx + 1}/{qs.length}</span>
          </div>
          <div class="question-visual">{q.visual}</div>
          <h3 class="screen-title">{q.prompt}</h3>
          <div class="options">
            {q.options.map((opt, optIdx) => (
              <button class="option" data-option={optIdx}>
                <span class="option-letter">{String.fromCharCode(65 + optIdx)}</span>
                <span class="option-text">{opt}</span>
              </button>
            ))}
          </div>
          <div class="feedback" data-feedback={`f-${idx}`}>
            <div class="feedback-head">
              <span class="feedback-emoji"></span>
              <span class="feedback-label"></span>
            </div>
            <p class="feedback-explanation">{t.explanation}: {q.explanation}</p>
            <button class="btn-quiz btn-quiz-primary" data-action="next" data-next={idx + 1}>
              {idx === qs.length - 1 ? t.score : t.next}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
        </div>
      ))}

      <!-- Result screen -->
      <div class="screen screen-result" data-screen="result">
        <div class="result-visual" id="result-emoji">🏆</div>
        <div class="result-score">
          <span id="result-value">0</span><span class="result-of">/{qs.length}</span>
        </div>
        <h3 class="screen-title" id="result-message">{t.score}</h3>
        <p class="screen-sub">{t.subtitle}</p>
        <div class="result-actions">
          <button class="btn-quiz btn-quiz-ghost" data-action="restart">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
            {t.restart}
          </button>
          <a href="#download" class="btn-quiz btn-quiz-primary">
            {t.download}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>

      <!-- Confetti -->
      <div class="confetti" id="confetti" aria-hidden="true"></div>
    </div>
  </div>
</section>

<script is:inline>
(() => {
  const card = document.getElementById('quiz-card');
  if (!card) return;

  const screens = card.querySelectorAll('.screen');
  const progressFill = document.getElementById('progress-fill');
  const total = card.querySelectorAll('[data-screen^="q-"]').length;
  let score = 0;

  const showScreen = (name) => {
    screens.forEach((s) => s.classList.toggle('active', s.dataset.screen === name));
    let step = 0;
    if (name === 'intro') step = 0;
    else if (name.startsWith('q-')) step = parseInt(name.split('-')[1]) + 1;
    else if (name === 'result') step = total + 1;
    if (progressFill) progressFill.style.width = `${(step / (total + 1)) * 100}%`;
  };

  const boomConfetti = () => {
    const host = document.getElementById('confetti');
    if (!host) return;
    host.innerHTML = '';
    const colors = ['#FF6B35', '#A855F7', '#FBBF24', '#14B8A6', '#22C55E'];
    for (let i = 0; i < 40; i++) {
      const p = document.createElement('span');
      p.className = 'confetto';
      p.style.setProperty('--c', colors[i % colors.length]);
      p.style.setProperty('--x', (Math.random() * 200 - 100) + 'px');
      p.style.setProperty('--y', -(Math.random() * 200 + 100) + 'px');
      p.style.setProperty('--r', Math.random() * 720 + 'deg');
      p.style.setProperty('--d', Math.random() * 0.3 + 's');
      host.appendChild(p);
    }
    setTimeout(() => { host.innerHTML = ''; }, 1600);
  };

  card.addEventListener('click', (e) => {
    const target = e.target;
    if (!(target instanceof HTMLElement)) return;

    const actionEl = target.closest('[data-action]');
    if (actionEl) {
      const action = actionEl.getAttribute('data-action');
      if (action === 'start') {
        score = 0;
        showScreen('q-0');
        return;
      }
      if (action === 'next') {
        const nextIdx = parseInt(actionEl.getAttribute('data-next') || '0');
        if (nextIdx >= total) {
          // result
          const valEl = document.getElementById('result-value');
          const msgEl = document.getElementById('result-message');
          const emojiEl = document.getElementById('result-emoji');
          if (valEl) valEl.textContent = String(score);
          if (emojiEl && msgEl) {
            if (score === total) {
              emojiEl.textContent = '🏆';
              msgEl.textContent = card.dataset.lang === 'en' ? 'Perfect score!' : card.dataset.lang === 'es' ? 'Puntuacion perfecta!' : 'Score parfait !';
              boomConfetti();
            } else if (score >= 2) {
              emojiEl.textContent = '🎯';
              msgEl.textContent = card.dataset.lang === 'en' ? 'Nicely done!' : card.dataset.lang === 'es' ? 'Bien hecho!' : 'Bien joué !';
            } else {
              emojiEl.textContent = '💪';
              msgEl.textContent = card.dataset.lang === 'en' ? 'Room to grow!' : card.dataset.lang === 'es' ? 'A practicar!' : 'Y\'a de la marge !';
            }
          }
          showScreen('result');
        } else {
          showScreen('q-' + nextIdx);
        }
        return;
      }
      if (action === 'restart') {
        score = 0;
        card.querySelectorAll('.option').forEach((o) => o.classList.remove('correct', 'wrong', 'revealed'));
        card.querySelectorAll('.feedback').forEach((f) => f.classList.remove('active'));
        showScreen('intro');
        return;
      }
    }

    const optEl = target.closest('.option');
    if (optEl && !optEl.classList.contains('revealed')) {
      const parent = optEl.closest('.screen-question');
      if (!parent) return;
      const correctIdx = parseInt(parent.getAttribute('data-answer') || '0');
      const chosen = parseInt(optEl.getAttribute('data-option') || '0');
      const options = parent.querySelectorAll('.option');
      options.forEach((o) => o.classList.add('revealed'));
      const correctOpt = options[correctIdx];
      if (correctOpt) correctOpt.classList.add('correct');
      const isRight = chosen === correctIdx;
      if (!isRight) optEl.classList.add('wrong');
      else score++;

      const screenName = parent.getAttribute('data-screen') || '';
      const idx = parseInt(screenName.split('-')[1]);
      const feedback = parent.querySelector(`[data-feedback="f-${idx}"]`);
      if (feedback) {
        const emoji = feedback.querySelector('.feedback-emoji');
        const label = feedback.querySelector('.feedback-label');
        const lang = card.dataset.lang;
        if (emoji) emoji.textContent = isRight ? '✅' : '❌';
        if (label) {
          label.textContent = isRight
            ? (lang === 'en' ? 'Nice!' : lang === 'es' ? 'Bien jugado !' : 'Bien joué !')
            : (lang === 'en' ? 'Almost…' : lang === 'es' ? 'Casi…' : 'Presque…');
        }
        feedback.classList.add('active');
      }
      if (isRight) boomConfetti();
    }
  });
})();
</script>

<style>
  .demo-quiz {
    background: linear-gradient(180deg, #F9FAFB 0%, #FFF 100%);
    padding: 96px 0;
  }

  .header-block {
    max-width: 720px;
    margin: 0 auto 48px;
    text-align: center;
  }

  .kicker {
    display: inline-block;
    padding: 6px 14px;
    background: rgba(255, 107, 53, 0.1);
    color: #ff6b35;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin-bottom: 20px;
  }

  .title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: #0a0a0f;
    margin-bottom: 16px;
  }

  .subtitle {
    font-size: 1.1rem;
    color: #6b7280;
    line-height: 1.6;
  }

  .quiz-card {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
    background: #fff;
    border-radius: 28px;
    box-shadow: 0 40px 80px -20px rgba(15, 15, 30, 0.15), 0 0 0 1px rgba(15, 15, 30, 0.04);
    overflow: hidden;
    min-height: 520px;
  }

  .progress {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: rgba(15, 15, 30, 0.05);
    z-index: 2;
  }

  .progress-fill {
    height: 100%;
    width: 0;
    background: linear-gradient(90deg, #ff6b35, #fbbf24);
    transition: width 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .screen {
    display: none;
    padding: 56px 48px;
    flex-direction: column;
    align-items: center;
    text-align: center;
    animation: screenIn 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .screen.active { display: flex; }

  @keyframes screenIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .intro-visual, .question-visual, .result-visual {
    font-size: 72px;
    margin-bottom: 24px;
    line-height: 1;
    filter: drop-shadow(0 8px 20px rgba(0, 0, 0, 0.1));
  }

  .result-visual { font-size: 84px; }

  .question-meta {
    margin-bottom: 16px;
  }

  .question-num {
    display: inline-block;
    padding: 4px 12px;
    background: #f3f4f6;
    color: #6b7280;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .screen-title {
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    font-weight: 700;
    color: #0a0a0f;
    margin-bottom: 12px;
    line-height: 1.3;
  }

  .screen-sub {
    font-size: 0.98rem;
    color: #6b7280;
    margin-bottom: 24px;
    max-width: 480px;
    line-height: 1.55;
  }

  .options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    width: 100%;
    max-width: 560px;
    margin-top: 24px;
  }

  .option {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    background: #fff;
    border: 2px solid #e5e7eb;
    border-radius: 14px;
    text-align: left;
    transition: all 0.2s;
    font-size: 15px;
    color: #0a0a0f;
  }

  .option:not(.revealed):hover {
    border-color: #ff6b35;
    background: #fff7f3;
    transform: translateY(-1px);
  }

  .option-letter {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: #f3f4f6;
    color: #6b7280;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 700;
    flex-shrink: 0;
    transition: all 0.2s;
  }

  .option:not(.revealed):hover .option-letter {
    background: #ff6b35;
    color: #fff;
  }

  .option-text { font-weight: 500; }

  .option.revealed { cursor: default; }
  .option.revealed:not(.correct):not(.wrong) { opacity: 0.5; }

  .option.correct {
    border-color: #22c55e;
    background: #f0fdf4;
    animation: correctPulse 0.5s ease-out;
  }
  .option.correct .option-letter {
    background: #22c55e;
    color: #fff;
  }

  .option.wrong {
    border-color: #ef4444;
    background: #fef2f2;
    animation: wrongShake 0.4s ease-out;
  }
  .option.wrong .option-letter {
    background: #ef4444;
    color: #fff;
  }

  @keyframes correctPulse {
    0%, 100% { scale: 1; }
    50% { scale: 1.03; }
  }

  @keyframes wrongShake {
    0%, 100% { translate: 0; }
    25% { translate: -6px; }
    75% { translate: 6px; }
  }

  .feedback {
    width: 100%;
    max-width: 560px;
    margin-top: 20px;
    padding: 18px 20px;
    background: #f9fafb;
    border-radius: 14px;
    text-align: left;
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transition: opacity 0.3s, max-height 0.4s;
  }

  .feedback.active {
    opacity: 1;
    max-height: 300px;
    padding: 18px 20px 20px;
  }

  .feedback-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
    font-weight: 700;
    color: #0a0a0f;
  }

  .feedback-emoji { font-size: 20px; }

  .feedback-explanation {
    font-size: 14px;
    color: #4b5563;
    line-height: 1.55;
    margin-bottom: 16px;
  }

  .btn-quiz {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 22px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 15px;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
  }

  .btn-quiz-primary {
    background: linear-gradient(135deg, #ff6b35, #ff8f5c);
    color: #fff;
    box-shadow: 0 8px 20px -6px rgba(255, 107, 53, 0.5);
  }

  .btn-quiz-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 30px -6px rgba(255, 107, 53, 0.6);
  }

  .btn-quiz-ghost {
    background: #f3f4f6;
    color: #0a0a0f;
  }

  .btn-quiz-ghost:hover { background: #e5e7eb; }

  .result-score {
    font-size: 4rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, #ff6b35, #fbbf24);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin-bottom: 8px;
    line-height: 1;
  }

  .result-of { font-size: 2rem; color: rgba(0, 0, 0, 0.3); -webkit-text-fill-color: initial; background: none; }

  .result-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 16px;
  }

  /* Confetti */
  .confetti {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 5;
  }

  .confetto {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 10px;
    height: 14px;
    background: var(--c);
    border-radius: 2px;
    animation: confettiFly 1.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--d);
  }

  @keyframes confettiFly {
    0% {
      transform: translate(0, 0) rotate(0);
      opacity: 1;
    }
    100% {
      transform: translate(var(--x), var(--y)) rotate(var(--r));
      opacity: 0;
    }
  }

  @media (max-width: 640px) {
    .demo-quiz { padding: 64px 0; }
    .screen { padding: 40px 24px; }
    .options { grid-template-columns: 1fr; }
    .intro-visual, .question-visual { font-size: 56px; }
    .result-visual { font-size: 64px; }
    .result-score { font-size: 3rem; }
    .quiz-card { border-radius: 20px; }
  }
</style>

---
import type { Lang } from '../i18n';
import { getLocalePath } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const content = {
  fr: {
    title: "Gratuit et sans pub",
    subtitle: "SAPIRO est 100% gratuit. Débloquez Sapiro+ pour accéder à 50+ parcours exclusifs.",
    free: "Gratuit pour toujours",
    freeDetails: "4 univers, 12 parcours, tous les modes de jeu",
    pro: "Sapiro+",
    proDetails: "50+ parcours, musées, familles animales, empires...",
    proPrice: "à partir de 1,99 €/mois",
    cta: "Voir les offres"
  },
  en: {
    title: "Free and ad-free",
    subtitle: "SAPIRO is 100% free. Unlock Sapiro+ to access 50+ exclusive paths.",
    free: "Free forever",
    freeDetails: "4 universes, 12 paths, all game modes",
    pro: "Sapiro+",
    proDetails: "50+ paths, museums, animal families, empires...",
    proPrice: "from $1.99/month",
    cta: "See plans"
  },
  es: {
    title: "Gratis y sin publicidad",
    subtitle: "SAPIRO es 100% gratis. Desbloquea Sapiro+ para acceder a 50+ recorridos exclusivos.",
    free: "Gratis para siempre",
    freeDetails: "4 universos, 12 recorridos, todos los modos de juego",
    pro: "Sapiro+",
    proDetails: "50+ recorridos, museos, familias animales, imperios...",
    proPrice: "desde 1,99 €/mes",
    cta: "Ver planes"
  }
};

const t = content[lang];
---

<section class="pricing-teaser section">
  <div class="container">
    <div class="section-header">
      <h2>{t.title}</h2>
      <p class="section-subtitle">{t.subtitle}</p>
    </div>

    <div class="teaser-cards">
      <div class="teaser-card free">
        <div class="teaser-badge free-badge">{t.free}</div>
        <p class="teaser-details">{t.freeDetails}</p>
      </div>

      <div class="teaser-card pro">
        <div class="teaser-badge pro-badge">{t.pro}</div>
        <p class="teaser-details">{t.proDetails}</p>
        <p class="teaser-price">{t.proPrice}</p>
      </div>
    </div>

    <div class="teaser-cta">
      <a href={getLocalePath('/pricing', lang)} class="btn btn-primary">{t.cta}</a>
    </div>
  </div>
</section>

<style>
  .pricing-teaser {
    background: var(--blanc);
  }

  .section-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .section-header h2 {
    margin-bottom: 16px;
  }

  .section-subtitle {
    font-size: 1.25rem;
    color: var(--gris);
  }

  .teaser-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 700px;
    margin: 0 auto 40px;
  }

  .teaser-card {
    padding: 32px 24px;
    border-radius: var(--border-radius);
    text-align: center;
    box-shadow: var(--shadow);
  }

  .teaser-card.free {
    background: var(--gris-clair);
    border-top: 4px solid var(--gris);
  }

  .teaser-card.pro {
    background: linear-gradient(180deg, rgba(255, 107, 53, 0.05) 0%, var(--blanc) 100%);
    border-top: 4px solid var(--orange);
  }

  .teaser-badge {
    display: inline-block;
    padding: 6px 16px;
    border-radius: 20px;
    font-weight: 700;
    font-size: 0.9rem;
    margin-bottom: 12px;
  }

  .free-badge {
    background: var(--blanc);
    color: var(--noir);
  }

  .pro-badge {
    background: var(--orange);
    color: var(--blanc);
  }

  .teaser-details {
    color: var(--gris);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .teaser-price {
    margin-top: 12px;
    font-weight: 700;
    color: var(--orange);
    font-size: 1rem;
  }

  .teaser-cta {
    text-align: center;
  }

  @media (max-width: 640px) {
    .teaser-cards {
      grid-template-columns: 1fr;
      max-width: 350px;
    }
  }
</style>

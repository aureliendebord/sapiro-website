---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import BlogCard from '../../../components/BlogCard.astro';
import PageHeroV2 from '../../../components/v2/PageHeroV2.astro';
import DownloadV2 from '../../../components/v2/DownloadV2.astro';
import StickyMobileCta from '../../../components/v2/StickyMobileCta.astro';
import { getTranslations } from '../../../i18n';

const lang = 'es';
const t = getTranslations(lang);

const posts = (await getCollection('blog', ({ data }) => data.lang === 'es'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = Object.keys(t.blog.categories);
const categoryCounts: Record<string, number> = {};
posts.forEach(p => {
  categoryCounts[p.data.category] = (categoryCounts[p.data.category] || 0) + 1;
});

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: t.blog.title,
  description: t.blog.subtitle,
  url: 'https://sapiro.app/es/blog/',
  publisher: {
    '@type': 'Organization',
    name: 'SAPIRO',
    logo: { '@type': 'ImageObject', url: 'https://sapiro.app/images/icon-1024.png' }
  },
  blogPost: posts.map(post => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.date.toISOString(),
    url: `https://sapiro.app/es/blog/${post.data.urlSlug}/`,
    author: { '@type': 'Organization', name: post.data.author }
  }))
};
---

<Layout title={`${t.blog.title} | SAPIRO`} description={t.blog.subtitle} lang={lang}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
  </Fragment>
  <Header lang={lang} t={t} />

  <main class="page-main">
    <PageHeroV2
      lang={lang}
      kicker="✍️ Blog"
      title="Aprender, jugar,"
      highlight="entender."
      subtitle={t.blog.subtitle}
      backLabel={t.header.home}
    />

    <section class="blog-listing">
      <div class="container">
        <div class="filters">
          <button class="filter-btn active" data-filter="all">
            {t.blog.allArticles} <span class="count">{posts.length}</span>
          </button>
          {categories.map(cat => (
            categoryCounts[cat] && (
              <button class="filter-btn" data-filter={cat}>
                {t.blog.categories[cat]} <span class="count">{categoryCounts[cat]}</span>
              </button>
            )
          ))}
        </div>

        <div class="grid">
          {posts.map((post) => (
            <div class="card-wrap" data-category={post.data.category}>
              <BlogCard
                title={post.data.title}
                description={post.data.description}
                date={post.data.date}
                slug={post.data.urlSlug}
                category={post.data.category}
                readingTime={post.data.readingTime}
                lang={lang}
              />
            </div>
          ))}
        </div>
      </div>
    </section>

    <DownloadV2 lang={lang} />
  </main>

  <Footer lang={lang} t={t} />
  <StickyMobileCta lang={lang} />
</Layout>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.card-wrap');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      cards.forEach(card => {
        const el = card as HTMLElement;
        el.style.display = (filter === 'all' || el.dataset.category === filter) ? '' : 'none';
      });
    });
  });
</script>

<style>
  .blog-listing {
    padding: 64px 0 80px;
    background: #fff;
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin-bottom: 48px;
  }

  .filter-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border: 1.5px solid #e5e7eb;
    border-radius: 999px;
    background: #fff;
    color: #4b5563;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .filter-btn .count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    height: 22px;
    padding: 0 6px;
    background: #f3f4f6;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    color: #6b7280;
  }

  .filter-btn:hover {
    border-color: #ff6b35;
    color: #ff6b35;
    transform: translateY(-1px);
  }

  .filter-btn.active {
    background: linear-gradient(135deg, #ff6b35, #ff8f5c);
    border-color: transparent;
    color: #fff;
    box-shadow: 0 8px 20px -6px rgba(255, 107, 53, 0.5);
  }

  .filter-btn.active .count {
    background: rgba(255, 255, 255, 0.25);
    color: #fff;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .card-wrap { display: flex; }
  .card-wrap > :global(a) { width: 100%; }

  @media (max-width: 1024px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .blog-listing { padding: 48px 0 64px; }
    .grid { grid-template-columns: 1fr; }
    .filter-btn { padding: 8px 14px; font-size: 13px; }
  }

  .page-main > section {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1), transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .page-main > section.revealed,
  .page-main > section:first-child {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .page-main > section {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

<script is:inline>
(() => {
  const sections = document.querySelectorAll('.page-main > section');
  if (!('IntersectionObserver' in window)) {
    sections.forEach((s) => s.classList.add('revealed'));
    return;
  }
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        e.target.classList.add('revealed');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  sections.forEach((s) => io.observe(s));
})();
</script>

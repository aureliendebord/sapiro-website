---
interface Props {
  t: any;
}

const { t } = Astro.props;

const colorMap: Record<string, string> = {
  orange: 'var(--orange)',
  violet: 'var(--violet)',
  vert: 'var(--vert)',
  teal: 'var(--teal)'
};
---

<section id="features" class="universes section">
  <div class="container">
    <div class="universes-header">
      <h2>{t.universes.title}</h2>
      <p class="universes-subtitle">{t.universes.subtitle}</p>
    </div>

    <div class="universes-grid">
      {t.universes.items.map((item: any) => (
        <div
          class="universe-card"
          style={`--card-color: ${colorMap[item.color]}`}
        >
          {item.badge && (
            <span class="universe-badge">{item.badge}</span>
          )}
          <div class="universe-emoji">{item.emoji}</div>
          <h3>{item.title}</h3>
          <p class="universe-description">{item.description}</p>
          <span class="universe-stat">{item.stat}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .universes {
    background: var(--blanc);
  }

  .universes-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .universes-header h2 {
    margin-bottom: 16px;
  }

  .universes-subtitle {
    font-size: 1.25rem;
    color: var(--gris);
  }

  .universes-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .universe-card {
    background: var(--gris-clair);
    padding: 32px 24px;
    border-radius: var(--border-radius);
    text-align: center;
    transition: transform 0.3s, box-shadow 0.3s;
    border-top: 4px solid var(--card-color);
    position: relative;
    overflow: hidden;
  }

  .universe-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
  }

  .universe-badge {
    position: absolute;
    top: 16px;
    right: -32px;
    background: var(--card-color);
    color: var(--blanc);
    padding: 4px 40px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    transform: rotate(35deg);
    letter-spacing: 0.5px;
  }

  .universe-emoji {
    font-size: 3.5rem;
    margin-bottom: 16px;
    display: block;
  }

  .universe-card h3 {
    margin-bottom: 12px;
    font-size: 1.25rem;
  }

  .universe-description {
    color: var(--gris);
    line-height: 1.6;
    margin-bottom: 16px;
    font-size: 0.95rem;
  }

  .universe-stat {
    display: inline-block;
    background: var(--card-color);
    color: var(--blanc);
    padding: 6px 16px;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 700;
  }

  @media (max-width: 1024px) {
    .universes-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .universes-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin: 0 auto;
    }
  }
</style>

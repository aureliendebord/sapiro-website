---
interface Props {
  t: any;
}

const { t } = Astro.props;

const icons: Record<string, string> = {
  flag: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>`,
  building: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg>`,
  user: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
  globe: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>`,
  zap: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
  trophy: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>`
};

const colorMap: Record<string, string> = {
  orange: 'var(--orange)',
  violet: 'var(--violet)',
  vert: 'var(--vert)',
  jaune: 'var(--jaune)',
  coral: 'var(--coral)',
  teal: 'var(--teal)'
};
---

<section id="features" class="features section">
  <div class="container">
    <div class="features-header">
      <h2>{t.features.title}</h2>
      <p class="features-subtitle">{t.features.subtitle}</p>
    </div>

    <div class="features-grid">
      {t.features.items.map((item: any, index: number) => (
        <div
          class="feature-card"
          style={`--card-color: ${colorMap[item.color]}`}
        >
          <div class="feature-icon" set:html={icons[item.icon]} />
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    background: var(--blanc);
  }

  .features-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .features-header h2 {
    margin-bottom: 16px;
  }

  .features-subtitle {
    font-size: 1.25rem;
    color: var(--gris);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .feature-card {
    background: var(--gris-clair);
    padding: 32px;
    border-radius: var(--border-radius);
    text-align: center;
    transition: transform 0.3s, box-shadow 0.3s;
    border-top: 4px solid var(--card-color);
  }

  .feature-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
  }

  .feature-icon {
    width: 56px;
    height: 56px;
    margin: 0 auto 20px;
    color: var(--card-color);
  }

  .feature-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .feature-card h3 {
    margin-bottom: 12px;
    font-size: 1.25rem;
  }

  .feature-card p {
    color: var(--gris);
    line-height: 1.6;
  }

  @media (max-width: 968px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getTranslations } from '../../i18n';

const lang = 'es';
const t = getTranslations(lang);

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Geografía mundial: países, banderas, capitales",
  "description": "Todo sobre geografía mundial: 197 países, banderas, capitales, fronteras, culturas.",
  "url": "https://sapiro.app/es/geografia/",
  "inLanguage": "es"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "¿Cuántos países hay en el mundo?", "acceptedAnswer": { "@type": "Answer", "text": "Hay 197 países reconocidos en el mundo: 193 miembros de la ONU más el Vaticano, Palestina, Taiwán y Kosovo (según reconocimientos)." } },
    { "@type": "Question", "name": "¿Cuál es la capital de Australia?", "acceptedAnswer": { "@type": "Answer", "text": "La capital de Australia es Canberra, no Sídney ni Melbourne. Es una ciudad planeada creada en 1913 para resolver la rivalidad Sídney-Melbourne." } },
    { "@type": "Question", "name": "¿Cuáles son las banderas más difíciles de reconocer?", "acceptedAnswer": { "@type": "Answer", "text": "Las banderas más confundidas son Chad/Rumania (casi idénticas), Mónaco/Indonesia (rojo y blanco invertidos), Eslovaquia/Eslovenia (similares) y las banderas nórdicas entre sí." } },
    { "@type": "Question", "name": "¿Cuál es el país más pequeño del mundo?", "acceptedAnswer": { "@type": "Answer", "text": "El Vaticano es el país más pequeño del mundo con 0,49 km² y unos 825 habitantes. Le siguen Mónaco (2,02 km²) y Nauru (21 km²)." } },
    { "@type": "Question", "name": "¿Cómo aprender todos los países del mundo?", "acceptedAnswer": { "@type": "Answer", "text": "El método más eficaz es aprender por continente (no alfabéticamente), empezando por 30 países clave y ampliando. Quince minutos de quiz al día bastan para memorizar 197 países en 3-6 meses." } }
  ]
};
---

<Layout title="Geografía mundial: países, banderas, capitales | SAPIRO" description="Geografía mundial: 197 países, banderas, capitales, fronteras. Guías, quizzes y métodos para aprender de verdad." lang={lang}>
  <Fragment slot="head">
    <link rel="alternate" hreflang="es" href="https://sapiro.app/es/geografia/" />
    <link rel="alternate" hreflang="fr" href="https://sapiro.app/geographie/" />
    <link rel="alternate" hreflang="en" href="https://sapiro.app/en/geography/" />
    <script type="application/ld+json" set:html={JSON.stringify(collectionPageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <Header lang={lang} t={t} />

  <main class="pillar-page">
    <article class="container">
      <header class="pillar-header">
        <h1>Geografía mundial</h1>
        <p class="lede">197 países, miles de banderas, capitales que confundimos. Todas nuestras guías y quizzes para dominar la geografía mundial.</p>
      </header>

      <section class="pillar-intro">
        <p>La geografía es probablemente la puerta de entrada más accesible a la cultura general. También es el campo que mejor se presta al quiz: las preguntas son factuales y verificables. Una capital, una bandera, una frontera. Uno sabe dónde está. Uno ve cómo progresa.</p>
        <p>SAPIRO cubre los 197 países reconocidos con banderas, capitales y particularidades, más preguntas temáticas (geografía económica, clima, demografía).</p>
      </section>

      <section class="pillar-stats">
        <h2>La geografía en cifras</h2>
        <ul>
          <li><strong>197</strong> países reconocidos en el mundo (193 miembros ONU + 4 casos especiales)</li>
          <li><strong>7</strong> continentes (África, América del Norte, América del Sur, Europa, Asia, Oceanía, Antártida)</li>
          <li><strong>~6 500</strong> idiomas hablados en el mundo</li>
          <li><strong>54</strong> países en África, un cuarto del planeta</li>
          <li><strong>270 000</strong> islas en Suecia, más que cualquier otro país</li>
        </ul>
      </section>

      <section class="pillar-sub">
        <h2>Lo esencial</h2>
        <ul class="pillar-grid">
          <li><a href="/es/blog/quiz-capitales-mundo/">Quiz capitales del mundo</a></li>
          <li><a href="/es/blog/quiz-capitales-por-continente/">Quiz capitales por continente</a></li>
          <li><a href="/es/blog/banderas-dificiles/">Las 15 banderas más difíciles</a></li>
          <li><a href="/es/blog/significado-banderas/">Significado de las banderas</a></li>
          <li><a href="/es/blog/errores-geografia/">Errores comunes de geografía</a></li>
          <li><a href="/es/blog/quiz-banderas-mundo-gratis-online/">Quiz banderas gratis online</a></li>
        </ul>
      </section>

      <section class="pillar-sub">
        <h2>Curiosidades geográficas</h2>
        <ul class="pillar-grid">
          <li><a href="/es/blog/paises-menos-visitados-mundo/">Los 15 países menos visitados</a></li>
          <li><a href="/es/blog/paises-mas-pequenos-mundo/">Los 10 países más pequeños</a></li>
          <li><a href="/es/blog/paises-desaparecidos/">Países que ya no existen</a></li>
          <li><a href="/es/blog/fronteras-extranas-mundo/">Las 10 fronteras más extrañas</a></li>
          <li><a href="/es/blog/origen-nombres-paises/">El origen del nombre de los países</a></li>
          <li><a href="/es/blog/test-pais-personalidad/">¿Qué país corresponde a tu personalidad?</a></li>
        </ul>
      </section>

      <section class="pillar-sub">
        <h2>Aprender en familia y en la escuela</h2>
        <ul class="pillar-grid">
          <li><a href="/es/blog/geografia-ninos/">Geografía para niños</a></li>
          <li><a href="/es/blog/geografia-familia/">Geografía en familia</a></li>
          <li><a href="/es/blog/ensenar-paises-mundo-ninos/">Enseñar los países a los niños</a></li>
          <li><a href="/es/blog/mejores-apps-geografia/">Las mejores apps de geografía</a></li>
        </ul>
      </section>

      <section class="pillar-faq">
        <h2>Preguntas frecuentes sobre geografía</h2>

        <h3>¿Cuántos países hay en el mundo?</h3>
        <p>Hay 197 países reconocidos en el mundo: 193 miembros de la ONU más el Vaticano, Palestina, Taiwán y Kosovo (según reconocimientos).</p>

        <h3>¿Cuál es la capital de Australia?</h3>
        <p>La capital de Australia es Canberra, no Sídney ni Melbourne. Es una ciudad planeada creada en 1913 para resolver la rivalidad Sídney-Melbourne.</p>

        <h3>¿Cuáles son las banderas más difíciles de reconocer?</h3>
        <p>Las banderas más confundidas son Chad/Rumania (casi idénticas), Mónaco/Indonesia (rojo y blanco invertidos), Eslovaquia/Eslovenia (similares) y las banderas nórdicas entre sí.</p>

        <h3>¿Cuál es el país más pequeño del mundo?</h3>
        <p>El Vaticano es el país más pequeño del mundo con 0,49 km² y unos 825 habitantes. Le siguen Mónaco (2,02 km²) y Nauru (21 km²).</p>

        <h3>¿Cómo aprender todos los países del mundo?</h3>
        <p>El método más eficaz es aprender por continente (no alfabéticamente), empezando por 30 países clave y ampliando. Quince minutos de quiz al día bastan para memorizar 197 países en 3-6 meses.</p>
      </section>
    </article>
  </main>

  <Footer lang={lang} t={t} />
</Layout>

<style>
  .pillar-page { padding-top: 100px; padding-bottom: 60px; }
  .pillar-header { text-align: center; padding-bottom: 32px; margin-bottom: 32px; border-bottom: 1px solid var(--gris-clair); }
  .pillar-header h1 { font-size: clamp(2.25rem, 4.5vw, 3.25rem); margin-bottom: 16px; }
  .lede { font-size: 1.25rem; color: var(--gris); max-width: 720px; margin: 0 auto; }
  .pillar-intro, .pillar-stats, .pillar-sub, .pillar-faq { max-width: 800px; margin: 0 auto 48px; }
  .pillar-intro p { line-height: 1.75; margin-bottom: 16px; font-size: 1.05rem; }
  .pillar-stats ul { padding-left: 24px; }
  .pillar-stats li { margin-bottom: 8px; line-height: 1.7; }
  .pillar-sub h2, .pillar-stats h2, .pillar-faq h2 { font-size: 1.75rem; margin-bottom: 20px; }
  .pillar-grid { list-style: none; padding: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 12px; }
  .pillar-grid li { padding: 14px 18px; background: var(--gris-clair); border-radius: 8px; }
  .pillar-grid a { color: var(--noir); text-decoration: none; font-weight: 500; }
  .pillar-grid a:hover { color: var(--orange); }
  .pillar-faq h3 { font-size: 1.1rem; margin-top: 24px; margin-bottom: 8px; }
  .pillar-faq p { line-height: 1.7; margin-bottom: 16px; }
</style>

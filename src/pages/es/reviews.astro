---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getTranslations, getLocalePath } from '../../i18n';

const lang = 'es';
const t = getTranslations(lang);

const reviewsSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "SAPIRO",
  "applicationCategory": "EducationalApplication",
  "operatingSystem": "iOS, Android",
  "url": "https://sapiro.app/es/reviews/",
  "description": "Quiz de cultura general: geografía, historia, arte y naturaleza. 2000+ preguntas para aprender divirtiéndote.",
  "screenshot": "https://sapiro.app/images/icon-1024.png",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5",
    "reviewCount": String(t.reviews.items.length),
    "bestRating": "5",
    "worstRating": "1"
  },
  "review": t.reviews.items.map((item: any) => ({
    "@type": "Review",
    "author": {
      "@type": "Person",
      "name": item.name
    },
    "reviewRating": {
      "@type": "Rating",
      "ratingValue": String(item.rating),
      "bestRating": "5"
    },
    "reviewBody": item.text
  }))
};
---

<Layout title={`${t.reviews.title} - SAPIRO`} description={t.reviews.metaDescription} lang={lang}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(reviewsSchema)} />
  </Fragment>
  <Header lang={lang} t={t} />

  <main class="reviews-page">
    <div class="container">
      <a href={getLocalePath('/', lang)} class="back-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        {t.header.home}
      </a>

      <!-- Header -->
      <div class="reviews-header">
        <h1>{t.reviews.title}</h1>
        <div class="rating-display">
          <span class="rating-number">5/5</span>
          <div class="stars">
            {[1, 2, 3, 4, 5].map(() => (
              <svg class="star" width="28" height="28" viewBox="0 0 24 24" fill="#FF6B35">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>
        </div>
        <p class="reviews-subtitle">{t.reviews.subtitle}</p>
      </div>

      <!-- Review cards grid -->
      <div class="reviews-grid">
        {t.reviews.items.map((review: any) => (
          <div class="review-card">
            <div class="review-header">
              <div class="review-author">
                <span class="review-name">{review.name}</span>
                <span class="review-role">{review.role}</span>
              </div>
              <div class="review-stars">
                {Array.from({ length: review.rating }).map(() => (
                  <svg class="star-small" width="18" height="18" viewBox="0 0 24 24" fill="#FF6B35">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                ))}
              </div>
            </div>
            <p class="review-text">{review.text}</p>
            <div class="review-store">
              {review.store === 'App Store' ? (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.71 19.5C17.88 20.74 17 21.95 15.66 21.97C14.32 22 13.89 21.18 12.37 21.18C10.84 21.18 10.37 21.95 9.09997 22C7.78997 22.05 6.79997 20.68 5.95997 19.47C4.24997 17 2.93997 12.45 4.69997 9.39C5.56997 7.87 7.12997 6.91 8.81997 6.88C10.1 6.86 11.32 7.75 12.11 7.75C12.89 7.75 14.37 6.68 15.92 6.84C16.57 6.87 18.39 7.1 19.56 8.82C19.47 8.88 17.39 10.1 17.41 12.63C17.44 15.65 20.06 16.66 20.09 16.67C20.06 16.74 19.67 18.11 18.71 19.5ZM13 3.5C13.73 2.67 14.94 2.04 15.94 2C16.07 3.17 15.6 4.35 14.9 5.19C14.21 6.04 13.07 6.7 11.95 6.61C11.8 5.46 12.36 4.26 13 3.5Z"/>
                </svg>
              ) : (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M3 20.5V3.5C3 2.91 3.34 2.39 3.84 2.15L13.69 12L3.84 21.85C3.34 21.6 3 21.09 3 20.5ZM16.81 15.12L6.05 21.34L14.54 12.85L16.81 15.12ZM20.16 10.81C20.5 11.08 20.75 11.5 20.75 12C20.75 12.5 20.5 12.92 20.16 13.19L17.89 14.5L15.39 12L17.89 9.5L20.16 10.81ZM6.05 2.66L16.81 8.88L14.54 11.15L6.05 2.66Z"/>
                </svg>
              )}
              <span>{review.store}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA ancho completo -->
    <section class="reviews-cta">
      <div class="container cta-content">
        <div class="cta-icon">
          <img src="/images/icon-180.png" alt="SAPIRO" width="100" height="100" />
        </div>

        <div class="cta-buttons">
          <a href="https://apps.apple.com/app/sapiro/id6757706883" class="btn btn-primary store-btn" target="_blank" rel="noopener noreferrer">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.71 19.5C17.88 20.74 17 21.95 15.66 21.97C14.32 22 13.89 21.18 12.37 21.18C10.84 21.18 10.37 21.95 9.09997 22C7.78997 22.05 6.79997 20.68 5.95997 19.47C4.24997 17 2.93997 12.45 4.69997 9.39C5.56997 7.87 7.12997 6.91 8.81997 6.88C10.1 6.86 11.32 7.75 12.11 7.75C12.89 7.75 14.37 6.68 15.92 6.84C16.57 6.87 18.39 7.1 19.56 8.82C19.47 8.88 17.39 10.1 17.41 12.63C17.44 15.65 20.06 16.66 20.09 16.67C20.06 16.74 19.67 18.11 18.71 19.5ZM13 3.5C13.73 2.67 14.94 2.04 15.94 2C16.07 3.17 15.6 4.35 14.9 5.19C14.21 6.04 13.07 6.7 11.95 6.61C11.8 5.46 12.36 4.26 13 3.5Z"/>
            </svg>
            <span>{t.reviews.cta} — App Store</span>
          </a>

          <a href="https://play.google.com/store/apps/details?id=com.sapiro.app" class="btn btn-primary store-btn" target="_blank" rel="noopener noreferrer">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M3 20.5V3.5C3 2.91 3.34 2.39 3.84 2.15L13.69 12L3.84 21.85C3.34 21.6 3 21.09 3 20.5ZM16.81 15.12L6.05 21.34L14.54 12.85L16.81 15.12ZM20.16 10.81C20.5 11.08 20.75 11.5 20.75 12C20.75 12.5 20.5 12.92 20.16 13.19L17.89 14.5L15.39 12L17.89 9.5L20.16 10.81ZM6.05 2.66L16.81 8.88L14.54 11.15L6.05 2.66Z"/>
            </svg>
            <span>{t.reviews.cta} — Google Play</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer lang={lang} t={t} />
</Layout>

<style>
  .reviews-page {
    padding-top: 120px;
    padding-bottom: 80px;
    min-height: 100vh;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--orange);
    font-weight: 500;
    margin-bottom: 32px;
    transition: gap 0.2s;
  }

  .back-link:hover {
    gap: 12px;
  }

  /* Header */
  .reviews-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 64px;
  }

  .reviews-header h1 {
    font-size: 2.5rem;
    margin-bottom: 24px;
  }

  .rating-display {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 16px;
  }

  .rating-number {
    font-size: 2rem;
    font-weight: 800;
    color: var(--noir);
  }

  .stars {
    display: flex;
    gap: 4px;
  }

  .reviews-subtitle {
    font-size: 1.1rem;
    color: var(--gris);
    line-height: 1.7;
  }

  /* Review cards grid */
  .reviews-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    max-width: 900px;
    margin: 0 auto 64px;
  }

  .review-card {
    background: var(--blanc);
    border-radius: var(--border-radius);
    padding: 32px;
    box-shadow: var(--shadow);
    border-left: 4px solid var(--orange);
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .review-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .review-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
  }

  .review-author {
    display: flex;
    flex-direction: column;
  }

  .review-name {
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--noir);
  }

  .review-role {
    font-size: 0.85rem;
    color: var(--gris);
    margin-top: 2px;
  }

  .review-stars {
    display: flex;
    gap: 2px;
    flex-shrink: 0;
  }

  .review-text {
    color: var(--noir);
    line-height: 1.7;
    font-size: 0.95rem;
    margin-bottom: 16px;
  }

  .review-store {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8rem;
    color: var(--gris);
    font-weight: 500;
  }

  /* CTA ancho completo */
  .reviews-cta {
    background: linear-gradient(135deg, var(--violet) 0%, var(--violet-light) 100%);
    color: var(--blanc);
    padding: 64px 24px;
    text-align: center;
  }

  .cta-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 600px;
  }

  .cta-icon {
    margin-bottom: 32px;
  }

  .cta-icon img {
    border-radius: 24px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
  }

  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
  }

  .store-btn {
    background: var(--blanc);
    color: var(--noir);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .reviews-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .reviews-header h1 {
      font-size: 2rem;
    }

    .rating-display {
      flex-direction: column;
      gap: 8px;
    }

    .cta-buttons {
      flex-direction: column;
      align-items: stretch;
    }

    .btn {
      justify-content: center;
    }
  }
</style>

---
import type { Lang } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const copy = {
  fr: { label: 'Télécharger SAPIRO', free: 'Gratuit', extra: 'Sans pub' },
  en: { label: 'Download SAPIRO', free: 'Free', extra: 'No ads' },
  es: { label: 'Descargar SAPIRO', free: 'Gratis', extra: 'Sin anuncios' },
};

const t = copy[lang];
---

<a href="#download" class="sticky-cta" id="sticky-cta" aria-label={t.label}>
  <span class="icon">⚡</span>
  <span class="text">
    <strong>{t.label}</strong>
    <small>{t.free} · {t.extra}</small>
  </span>
  <span class="arrow">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
  </span>
</a>

<script is:inline>
(() => {
  const cta = document.getElementById('sticky-cta');
  if (!cta) return;

  const show = () => cta.classList.add('visible');
  const hide = () => cta.classList.remove('visible');

  const onScroll = () => {
    if (window.scrollY > 600) show();
    else hide();
  };

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
})();
</script>

<style>
  .sticky-cta {
    position: fixed;
    left: 16px;
    right: 16px;
    bottom: 16px;
    z-index: 50;
    display: none;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: linear-gradient(135deg, #ff6b35 0%, #ff8f5c 100%);
    color: #fff;
    border-radius: 999px;
    box-shadow: 0 20px 40px -10px rgba(255, 107, 53, 0.55), 0 0 0 1px rgba(255, 255, 255, 0.1);
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.3s, transform 0.3s;
    text-decoration: none;
  }

  @media (max-width: 760px) {
    .sticky-cta { display: flex; }
  }

  .sticky-cta.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .icon {
    font-size: 22px;
    flex-shrink: 0;
  }

  .text {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
    line-height: 1.15;
  }

  .text strong {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .text small {
    font-size: 11px;
    opacity: 0.85;
    font-weight: 500;
  }

  .arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    flex-shrink: 0;
  }
</style>

---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang?: string;
  noDefaultHreflang?: boolean;
}

const { title, description, lang = 'fr', noDefaultHreflang = false } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL('/images/og/default.png', Astro.site);

// Build dynamic hreflang URLs based on current path
const pathname = Astro.url.pathname;
let frPath: string;
let enPath: string;
let esPath: string;

if (pathname.startsWith('/en/')) {
  const basePath = pathname.replace(/^\/en/, '');
  frPath = basePath;
  enPath = `/en${basePath}`;
  esPath = `/es${basePath}`;
} else if (pathname.startsWith('/es/')) {
  const basePath = pathname.replace(/^\/es/, '');
  frPath = basePath;
  enPath = `/en${basePath}`;
  esPath = `/es${basePath}`;
} else {
  frPath = pathname;
  enPath = `/en${pathname}`;
  esPath = `/es${pathname}`;
}

const hrefFr = `https://sapiro.app${frPath}`;
const hrefEn = `https://sapiro.app${enPath}`;
const hrefEs = `https://sapiro.app${esPath}`;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="author" content="SAPIRO" />

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="180x180" href="/images/icon-180.png" />
  <link rel="apple-touch-icon" href="/images/icon-180.png" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageURL.toString()} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL.toString()} />

  <!-- Canonical -->
  <link rel="canonical" href={canonicalURL} />

  <!-- Alternate languages (dynamic per page) -->
  {!noDefaultHreflang && (
    <>
      <link rel="alternate" hreflang="fr" href={hrefFr} />
      <link rel="alternate" hreflang="en" href={hrefEn} />
      <link rel="alternate" hreflang="es" href={hrefEs} />
      <link rel="alternate" hreflang="x-default" href={hrefFr} />
    </>
  )}

  <title>{title}</title>
  <slot name="head" />
</head>
<body>
  <slot />
</body>
</html>

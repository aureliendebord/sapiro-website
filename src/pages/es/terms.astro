---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getTranslations, getLocalePath } from '../../i18n';

const lang = 'es';
const t = getTranslations(lang);
const lastUpdate = '28 de enero de 2025';
---

<Layout title={`${t.terms.title} - SAPIRO`} description={t.terms.metaDescription} lang={lang}>
  <Header lang={lang} t={t} />

  <main class="terms-page">
    <div class="container">
      <a href={getLocalePath('/', lang)} class="back-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        {t.header.home}
      </a>

      <article class="terms-content">
        <h1>{t.terms.title}</h1>
        <p class="last-update">{t.terms.lastUpdate}: {lastUpdate}</p>

        <p class="intro">{t.terms.intro}</p>

        {t.terms.sections.map((section: any) => (
          <section class="terms-section">
            <h2>{section.title}</h2>
            <div class="section-content" set:html={section.content} />
          </section>
        ))}
      </article>
    </div>
  </main>

  <Footer lang={lang} t={t} />
</Layout>

<style>
  .terms-page {
    padding-top: 120px;
    padding-bottom: 80px;
    min-height: 100vh;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--orange);
    font-weight: 500;
    margin-bottom: 32px;
    transition: gap 0.2s;
  }

  .back-link:hover {
    gap: 12px;
  }

  .terms-content {
    max-width: 700px;
  }

  .terms-content h1 {
    font-size: 2.5rem;
    margin-bottom: 16px;
  }

  .last-update {
    color: var(--gris);
    margin-bottom: 32px;
  }

  .intro {
    font-size: 1.125rem;
    line-height: 1.7;
    margin-bottom: 48px;
    color: var(--noir);
  }

  .terms-section {
    margin-bottom: 32px;
  }

  .terms-section h2 {
    font-size: 1.25rem;
    color: var(--orange);
    margin-bottom: 12px;
  }

  .terms-section p,
  .section-content {
    color: var(--gris);
    line-height: 1.7;
  }

  .section-content h3 {
    font-size: 1.1rem;
    color: var(--noir);
    margin-top: 20px;
    margin-bottom: 8px;
  }

  .section-content ul {
    margin: 12px 0;
    padding-left: 24px;
  }

  .section-content li {
    margin-bottom: 8px;
  }

  .section-content p {
    margin-bottom: 12px;
  }

  .section-content strong {
    color: var(--noir);
  }
</style>

---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHeroV2 from '../../components/v2/PageHeroV2.astro';
import LegalContentV2 from '../../components/v2/LegalContentV2.astro';
import DownloadV2 from '../../components/v2/DownloadV2.astro';
import StickyMobileCta from '../../components/v2/StickyMobileCta.astro';
import { getTranslations } from '../../i18n';

const lang = 'en';
const t = getTranslations(lang);
const lastUpdate = 'January 28, 2025';
---

<Layout title={`${t.terms.title} - SAPIRO`} description={t.terms.metaDescription} lang={lang}>
  <Header lang={lang} t={t} />

  <main class="page-main">
    <PageHeroV2
      lang={lang}
      kicker="📜 Terms"
      title="The rules"
      highlight="of the game."
      subtitle={t.terms.intro}
      backLabel={t.header.home}
    />

    <LegalContentV2
      intro={t.terms.intro}
      lastUpdate={t.terms.lastUpdate}
      lastUpdateDate={lastUpdate}
      sections={t.terms.sections}
    />

    <DownloadV2 lang={lang} />
  </main>

  <Footer lang={lang} t={t} />
  <StickyMobileCta lang={lang} />
</Layout>

<style is:global>
  .page-main > section {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1), transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .page-main > section.revealed,
  .page-main > section:first-child {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .page-main > section {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

<script is:inline>
(() => {
  const sections = document.querySelectorAll('.page-main > section');
  if (!('IntersectionObserver' in window)) {
    sections.forEach((s) => s.classList.add('revealed'));
    return;
  }
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        e.target.classList.add('revealed');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  sections.forEach((s) => io.observe(s));
})();
</script>

---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n';
import { getTranslations } from '../i18n';

interface ArticleLink {
  title: string;
  url: string;
}
interface FaqEntry {
  q: string;
  a: string;
}
interface Props {
  lang: Lang;
  title: string;
  description: string;
  hreflang: { fr: string; en: string; es: string };
  h1: string;
  lede: string;
  intro: string[];
  statsTitle: string;
  stats: string[];
  articlesTitle: string;
  articles: ArticleLink[];
  faqTitle: string;
  faq: FaqEntry[];
  collectionName: string;
}

const {
  lang, title, description, hreflang, h1, lede, intro,
  statsTitle, stats, articlesTitle, articles, faqTitle, faq, collectionName,
} = Astro.props;

const t = getTranslations(lang);
const canonical = hreflang[lang];

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: collectionName,
  description: description,
  url: canonical,
  inLanguage: lang,
  isPartOf: { '@type': 'WebSite', name: 'SAPIRO', url: 'https://sapiro.app' },
  hasPart: articles.map((a) => ({ '@type': 'Article', name: a.title, url: a.url })),
};

const faqSchema = faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;
---

<Layout title={`${title} | SAPIRO`} description={description} lang={lang} noDefaultHreflang={true}>
  <Fragment slot="head">
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="fr" href={hreflang.fr} />
    <link rel="alternate" hreflang="en" href={hreflang.en} />
    <link rel="alternate" hreflang="es" href={hreflang.es} />
    <link rel="alternate" hreflang="x-default" href={hreflang.fr} />
    <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </Fragment>

  <Header lang={lang} t={t} />

  <main class="pillar-page">
    <article class="container">
      <header class="pillar-header">
        <h1>{h1}</h1>
        <p class="lede">{lede}</p>
      </header>

      <section class="pillar-intro">
        {intro.map((p) => <p>{p}</p>)}
      </section>

      <section class="pillar-stats">
        <h2>{statsTitle}</h2>
        <ul>
          {stats.map((s) => <li set:html={s} />)}
        </ul>
      </section>

      <section class="pillar-sub">
        <h2>{articlesTitle}</h2>
        <ul class="pillar-grid">
          {articles.map((a) => (
            <li><a href={a.url}>{a.title}</a></li>
          ))}
        </ul>
      </section>

      {faq.length > 0 && (
        <section class="pillar-faq">
          <h2>{faqTitle}</h2>
          {faq.map((f) => (
            <Fragment>
              <h3>{f.q}</h3>
              <p>{f.a}</p>
            </Fragment>
          ))}
        </section>
      )}
    </article>
  </main>

  <Footer lang={lang} t={t} />
</Layout>

<style>
  .pillar-page { padding-top: 100px; padding-bottom: 60px; }
  .pillar-header { text-align: center; padding-bottom: 32px; margin-bottom: 32px; border-bottom: 1px solid var(--gris-clair); }
  .pillar-header h1 { font-size: clamp(2.25rem, 4.5vw, 3.25rem); margin-bottom: 16px; }
  .lede { font-size: 1.25rem; color: var(--gris); max-width: 720px; margin: 0 auto; }
  .pillar-intro, .pillar-stats, .pillar-sub, .pillar-faq { max-width: 800px; margin: 0 auto 48px; }
  .pillar-intro :global(p) { line-height: 1.75; margin-bottom: 16px; font-size: 1.05rem; }
  .pillar-stats ul { padding-left: 24px; }
  .pillar-stats :global(li) { margin-bottom: 8px; line-height: 1.7; }
  .pillar-sub h2, .pillar-stats h2, .pillar-faq h2 { font-size: 1.75rem; margin-bottom: 20px; }
  .pillar-grid { list-style: none; padding: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 12px; }
  .pillar-grid li { padding: 14px 18px; background: var(--gris-clair); border-radius: 8px; }
  .pillar-grid a { color: var(--noir); text-decoration: none; font-weight: 500; }
  .pillar-grid a:hover { color: var(--orange); }
  .pillar-faq h3 { font-size: 1.1rem; margin-top: 24px; margin-bottom: 8px; }
  .pillar-faq p { line-height: 1.7; margin-bottom: 16px; }
</style>

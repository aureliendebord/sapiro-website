---
import type { Lang } from '../../i18n';
import { getLocalePath } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const copy = {
  fr: {
    kicker: 'Tarifs',
    title: 'Gratuit pour toujours.\nPremium pour les mordus.',
    subtitle: 'Zéro pub, zéro data, zéro piège. Choisis la formule qui te va.',
    freeTitle: 'Gratuit',
    freeSub: 'Pour toujours',
    freeFeatures: [
      '5 univers complets',
      '~12 parcours inclus',
      'Classique & Survie illimités',
      'Défi quotidien',
      'Aucune publicité',
      'Quiz sans connexion',
    ],
    freeCta: 'Télécharger gratuitement',
    plusTitle: 'Sapiro+',
    plusSub: 'Débloque les 54 parcours exclusifs',
    plusFeatures: [
      'Tout le contenu gratuit',
      'Les 54 parcours premium',
      'Drapeaux à étoiles, Louvre, célébrités d\'Afrique…',
      'Rejoue tes questions difficiles',
      'Sauvegarde ta partie Survie',
      'Bannières & badge exclusifs au classement',
    ],
    seeAll: 'Voir tous les détails',
  },
  en: {
    kicker: 'Pricing',
    title: 'Free forever.\nPremium for super-curious.',
    subtitle: 'Zero ads, zero data, zero tricks. Pick what fits.',
    freeTitle: 'Free',
    freeSub: 'Forever',
    freeFeatures: [
      '5 full universes',
      '~12 paths included',
      'Classic & Survival unlimited',
      'Daily challenge',
      'No ads',
      'Offline quizzes',
    ],
    freeCta: 'Download for free',
    plusTitle: 'Sapiro+',
    plusSub: 'Unlock all 54 exclusive paths',
    plusFeatures: [
      'Everything in Free',
      'All 54 premium paths',
      'Starred flags, the Louvre, African icons…',
      'Replay your tricky questions',
      'Save your Survival run',
      'Exclusive leaderboard banners & badge',
    ],
    seeAll: 'See full pricing',
  },
  es: {
    kicker: 'Precios',
    title: 'Gratis para siempre.\nPremium para los mas curiosos.',
    subtitle: 'Cero anuncios, cero datos, cero trampas. Elige lo que te va.',
    freeTitle: 'Gratis',
    freeSub: 'Para siempre',
    freeFeatures: [
      '5 universos completos',
      '~12 recorridos incluidos',
      'Clasico y Supervivencia sin limite',
      'Desafio diario',
      'Sin anuncios',
      'Quizzes sin conexion',
    ],
    freeCta: 'Descargar gratis',
    plusTitle: 'Sapiro+',
    plusSub: 'Desbloquea los 54 recorridos exclusivos',
    plusFeatures: [
      'Todo lo gratis',
      'Los 54 recorridos premium',
      'Banderas con estrellas, el Louvre, iconos de Africa…',
      'Repite tus preguntas dificiles',
      'Guarda tu partida de Supervivencia',
      'Banderines e insignia exclusivos del ranking',
    ],
    seeAll: 'Ver todos los detalles',
  },
};

const t = copy[lang];
---

<section class="pricing-v2">
  <div class="container">
    <div class="head">
      <span class="kicker"><img src="/images/icons/gem.webp" class="app-ico" alt="" aria-hidden="true" /> {t.kicker}</span>
      <h2 class="title">{t.title}</h2>
      <p class="subtitle">{t.subtitle}</p>
    </div>

    <div class="grid">
      <!-- FREE -->
      <article class="plan plan-free">
        <div class="plan-head">
          <h3>{t.freeTitle}</h3>
          <p class="plan-sub">{t.freeSub}</p>
        </div>
        <ul class="features">
          {t.freeFeatures.map((f) => (
            <li><span class="check">✓</span>{f}</li>
          ))}
        </ul>
        <a href="#download" class="plan-cta cta-ghost">{t.freeCta}</a>
      </article>

      <!-- PLUS -->
      <article class="plan plan-plus">
        <div class="plan-ribbon">Sapiro+</div>

        <div class="plan-head">
          <h3>{t.plusTitle}</h3>
          <p class="plan-sub">{t.plusSub}</p>
        </div>

        <ul class="features">
          {t.plusFeatures.map((f) => (
            <li><span class="check check-plus">✓</span>{f}</li>
          ))}
        </ul>

        <a href="#download" class="plan-cta cta-primary">{t.freeCta}</a>
        <a href={getLocalePath('/pricing', lang)} class="plan-link">{t.seeAll} →</a>
      </article>
    </div>
  </div>
</section>

<style>
  .pricing-v2 {
    background: #FAF3E9;
    padding: 96px 0;
  }

  .head {
    max-width: 720px;
    margin: 0 auto 56px;
    text-align: center;
  }

  .kicker {
    display: inline-block;
    padding: 6px 14px;
    background: rgba(20, 184, 166, 0.12);
    color: #0d9488;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 20px;
  }

  .title {
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: #0a0a0f;
    margin-bottom: 16px;
    white-space: pre-line;
  }

  .subtitle {
    font-size: 1.1rem;
    color: #6b7280;
    line-height: 1.6;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 920px;
    margin: 0 auto;
    align-items: stretch;
  }

  .plan {
    position: relative;
    background: #fff;
    border-radius: 28px;
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .plan-free {
    border: 1.5px solid rgba(31, 41, 55, 0.1);
    box-shadow: 0 14px 40px -24px rgba(0, 0, 0, 0.25);
  }

  .plan-plus {
    background: #fff;
    color: #1f2937;
    border: 2px solid #ff6b35;
    box-shadow: 0 40px 80px -34px rgba(255, 107, 53, 0.5);
    overflow: hidden;
  }

  .plan-plus::before {
    content: '';
    position: absolute;
    top: -120px;
    right: -120px;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 107, 53, 0.18), transparent 70%);
    pointer-events: none;
  }

  .plan-ribbon {
    position: absolute;
    top: 20px;
    right: 20px;
    padding: 6px 14px;
    background: linear-gradient(135deg, #ff6b35, #fbbf24);
    color: #fff;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    z-index: 2;
  }

  .plan-head h3 {
    font-size: 1.6rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 4px;
  }

  .plan-sub {
    font-size: 14px;
    color: #6b7280;
  }

  .plan-plus .plan-sub { color: #6b7280; }

  /* Features */
  .features {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .features li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: #374151;
  }

  .plan-plus .features li { color: #374151; }

  .check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    border-radius: 50%;
    background: #e5e7eb;
    color: #374151;
    font-size: 11px;
    font-weight: 800;
    margin-top: 1px;
  }

  .check-plus {
    background: linear-gradient(135deg, #ff6b35, #fbbf24);
    color: #fff;
  }

  .plan-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 14px 20px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 15px;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .cta-ghost {
    background: #fff;
    color: #1f2937;
    border: 1.5px solid rgba(31, 41, 55, 0.15);
  }

  .cta-ghost:hover { transform: translateY(-2px); box-shadow: 0 12px 28px -14px rgba(0,0,0,0.3); }

  .cta-primary {
    background: linear-gradient(135deg, #ff6b35, #ff8f5c);
    color: #fff;
    box-shadow: 0 10px 30px -8px rgba(255, 107, 53, 0.5);
  }

  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 40px -8px rgba(255, 107, 53, 0.65);
  }

  .plan-link {
    text-align: center;
    font-size: 13px;
    color: #6b7280;
    margin-top: -10px;
  }

  .plan-link:hover { color: #e55a2b; }

  @media (max-width: 840px) {
    .grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 520px) {
    .pricing-v2 { padding: 64px 0; }
    .plan { padding: 28px 22px; border-radius: 22px; }
  }
</style>

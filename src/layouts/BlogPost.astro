---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BlogCta from '../components/BlogCta.astro';
import type { Lang } from '../i18n';
import { getTranslations, getLocalePath } from '../i18n';
import type { FaqItem } from '../utils/faq';
import { getClusterForCategory } from '../data/clusters';

interface TranslationSlugs {
  fr: string;
  en: string;
  es: string;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  lastModified?: Date;
  lang: Lang;
  slug: string;
  category: string;
  author: string;
  authorRole?: string;
  readingTime?: number;
  faqItems?: FaqItem[];
  translationSlugs?: TranslationSlugs;
}

const { title, description, date, lastModified, lang, slug, category, author, authorRole, readingTime, faqItems = [], translationSlugs } = Astro.props;
const t = getTranslations(lang);
const modifiedDate = lastModified || date;
const authorIsPerson = author !== 'SAPIRO';

const formattedDate = date.toLocaleDateString(lang === 'fr' ? 'fr-FR' : lang === 'en' ? 'en-US' : 'es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const categoryLabel = t.blog.categories[category] || category;
const blogUrl = getLocalePath('/blog', lang);

// Cluster thematique de l'article (tete de silo)
const cluster = getClusterForCategory(category);
const clusterLabel = cluster ? cluster.label[lang] : null;
const clusterUrl = cluster ? cluster.pillarSlug[lang] : null;

// Hreflang pour cet article (avec trailing slash et slugs par langue)
const frSlug = translationSlugs?.fr || slug;
const enSlug = translationSlugs?.en || slug;
const esSlug = translationSlugs?.es || slug;

const hreflangs = [
  { lang: 'fr', href: `https://sapiro.app/blog/${frSlug}/` },
  { lang: 'en', href: `https://sapiro.app/en/blog/${enSlug}/` },
  { lang: 'es', href: `https://sapiro.app/es/blog/${esSlug}/` },
];

// Schema.org Article
const authorSchema = authorIsPerson ? {
  '@type': 'Person',
  name: author,
  ...(authorRole && { jobTitle: authorRole }),
  url: 'https://sapiro.app/about/aurelien-debord/',
  sameAs: [
    'https://www.linkedin.com/in/aureliendebord/',
  ]
} : {
  '@type': 'Organization',
  name: author,
  url: 'https://sapiro.app'
};

const schemaArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  author: authorSchema,
  publisher: {
    '@type': 'Organization',
    name: 'SAPIRO',
    logo: {
      '@type': 'ImageObject',
      url: 'https://sapiro.app/images/icon-1024.png'
    }
  },
  datePublished: date.toISOString(),
  dateModified: modifiedDate.toISOString(),
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://sapiro.app${getLocalePath(`/blog/${slug}`, lang)}`
  },
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['h1', '.article-content > p:first-of-type']
  },
  inLanguage: lang
};

// Schema.org FAQPage (si l'article contient une FAQ)
const schemaFaq = faqItems.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer
    }
  }))
} : null;

// Schema.org BreadcrumbList (avec le niveau cluster si disponible)
const breadcrumbItems: any[] = [
  { '@type': 'ListItem', position: 1, name: t.header.home, item: `https://sapiro.app${getLocalePath('/', lang)}` },
  { '@type': 'ListItem', position: 2, name: 'Blog', item: `https://sapiro.app${getLocalePath('/blog', lang)}` },
];
if (cluster && clusterUrl && clusterLabel) {
  breadcrumbItems.push({ '@type': 'ListItem', position: 3, name: clusterLabel, item: `https://sapiro.app${clusterUrl}` });
  breadcrumbItems.push({ '@type': 'ListItem', position: 4, name: title });
} else {
  breadcrumbItems.push({ '@type': 'ListItem', position: 3, name: title });
}
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems,
};
---

<Layout title={`${title} | SAPIRO`} description={description} lang={lang} noDefaultHreflang={true}>
  <Fragment slot="head">
    <!-- Hreflang spécifique à l'article -->
    {hreflangs.map(h => (
      <link rel="alternate" hreflang={h.lang} href={h.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={hreflangs[0].href} />

    <!-- Open Graph Article -->
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={date.toISOString()} />
    <meta property="article:author" content={author} />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaArticle)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {schemaFaq && <script type="application/ld+json" set:html={JSON.stringify(schemaFaq)} />}
  </Fragment>

  <Header lang={lang} t={t} />

  <main class="blog-post">
    <article class="container">
      <!-- Breadcrumbs -->
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href={getLocalePath('/', lang)}>{t.header.home}</a>
        <span class="breadcrumb-sep">&gt;</span>
        <a href={blogUrl}>Blog</a>
        {clusterUrl && clusterLabel && (
          <Fragment>
            <span class="breadcrumb-sep">&gt;</span>
            <a href={clusterUrl}>{clusterLabel}</a>
          </Fragment>
        )}
        <span class="breadcrumb-sep">&gt;</span>
        <span class="breadcrumb-current">{title}</span>
      </nav>

      <!-- Article Header -->
      <header class="article-header">
        <div class="article-meta">
          <span class="article-category">{categoryLabel}</span>
          {readingTime && <span class="article-reading">{readingTime} {t.blog.readingTime}</span>}
        </div>
        <h1>{title}</h1>
        <div class="article-info">
          <span>{t.blog.publishedOn} <time datetime={date.toISOString()}>{formattedDate}</time></span>
          <span class="article-author">— {author}</span>
        </div>
      </header>

      <!-- Article Content -->
      <div class="article-content" id="article-content">
        <slot />
        {clusterUrl && clusterLabel && (
          <aside class="cluster-box">
            <p>{t.blog.partOfTopic} <strong>{clusterLabel}</strong>.</p>
            <a href={clusterUrl} class="cluster-box-link">{t.blog.seeAllTopic} &rarr;</a>
          </aside>
        )}
        <BlogCta lang={lang} />
      </div>

      <script>
        // Wrap FAQ section in a styled container
        const content = document.getElementById('article-content');
        if (content) {
          const headings = content.querySelectorAll('h2');
          headings.forEach(h2 => {
            const text = h2.textContent?.toLowerCase() || '';
            if (text.includes('frequentes') || text.includes('asked questions') || text.includes('frecuentes') || text.includes('faq')) {
              const wrapper = document.createElement('div');
              wrapper.className = 'faq-section';
              h2.parentNode?.insertBefore(wrapper, h2);
              wrapper.appendChild(h2);
              // Move all siblings until next H2 or end
              let next = wrapper.nextSibling;
              while (next) {
                const el = next as Element;
                if (el.tagName === 'H2') break;
                const move = next;
                next = next.nextSibling;
                wrapper.appendChild(move);
              }
            }
          });
        }
      </script>

      <!-- Back to blog -->
      <div class="article-back">
        <a href={blogUrl} class="btn btn-secondary">&larr; {t.blog.backToBlog}</a>
      </div>
    </article>
  </main>

  <Footer lang={lang} t={t} />
</Layout>

<style>
  .blog-post {
    padding-top: 72px;
  }

  .breadcrumbs {
    padding: 24px 0;
    font-size: 14px;
    color: var(--gris);
  }

  .breadcrumbs a {
    color: var(--gris);
    transition: color 0.2s;
  }

  .breadcrumbs a:hover {
    color: var(--orange);
  }

  .breadcrumb-sep {
    margin: 0 8px;
    color: var(--gris);
    opacity: 0.5;
  }

  .breadcrumb-current {
    color: var(--noir);
    font-weight: 500;
  }

  .article-header {
    padding-bottom: 32px;
    border-bottom: 1px solid var(--gris-clair);
    margin-bottom: 32px;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .article-category {
    display: inline-block;
    padding: 4px 14px;
    background: rgba(255, 107, 53, 0.1);
    color: var(--orange);
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
  }

  .article-reading {
    font-size: 13px;
    color: var(--gris);
  }

  .article-header h1 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    line-height: 1.2;
    margin-bottom: 16px;
    color: var(--noir);
  }

  .article-info {
    font-size: 15px;
    color: var(--gris);
  }

  .article-author {
    font-weight: 500;
  }

  .article-content {
    max-width: 720px;
    margin: 0 auto;
    padding-bottom: 48px;
  }

  .article-content :global(h2) {
    font-size: 1.75rem;
    margin: 40px 0 16px;
    color: var(--noir);
  }

  .article-content :global(h3) {
    font-size: 1.25rem;
    margin: 32px 0 12px;
    color: var(--noir);
  }

  .article-content :global(p) {
    margin-bottom: 16px;
    line-height: 1.8;
    color: var(--noir);
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin-bottom: 16px;
    padding-left: 24px;
  }

  .article-content :global(li) {
    margin-bottom: 8px;
    line-height: 1.7;
  }

  .article-content :global(strong) {
    font-weight: 600;
    color: var(--noir);
  }

  .article-content :global(a:not(.btn)) {
    color: var(--orange);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }

  .article-content :global(a:not(.btn):hover) {
    color: var(--orange-dark);
  }

  .article-content :global(blockquote) {
    border-left: 4px solid var(--orange);
    padding: 16px 24px;
    margin: 24px 0;
    background: var(--gris-clair);
    border-radius: 0 var(--border-radius-sm) var(--border-radius-sm) 0;
    font-style: italic;
  }

  /* Tables */
  .article-content :global(table) {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin: 32px 0 40px;
    font-size: 0.88rem;
    line-height: 1.6;
    overflow-x: auto;
    display: block;
    border-radius: 12px;
    border: 1px solid rgba(255, 107, 53, 0.15);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  }

  .article-content :global(thead) {
    background: linear-gradient(135deg, rgba(255, 107, 53, 0.08) 0%, rgba(255, 107, 53, 0.04) 100%);
  }

  .article-content :global(th) {
    padding: 14px 18px;
    text-align: left;
    font-weight: 700;
    color: var(--orange);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    border-bottom: 2px solid var(--orange);
    white-space: nowrap;
  }

  .article-content :global(td) {
    padding: 14px 18px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    color: var(--noir);
    vertical-align: top;
  }

  .article-content :global(tbody tr:last-child td) {
    border-bottom: none;
  }

  .article-content :global(tbody tr:hover) {
    background: rgba(255, 107, 53, 0.04);
  }

  .article-content :global(tbody tr:nth-child(even)) {
    background: rgba(0, 0, 0, 0.015);
  }

  .article-content :global(tbody tr:nth-child(even):hover) {
    background: rgba(255, 107, 53, 0.06);
  }

  .article-content :global(td:first-child) {
    font-weight: 600;
    color: var(--noir);
  }

  /* Images dans les articles */
  .article-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    margin: 24px 0;
    display: block;
  }

  .article-content :global(figure) {
    margin: 32px 0;
    text-align: center;
  }

  .article-content :global(figcaption) {
    font-size: 0.85rem;
    color: var(--gris);
    margin-top: 8px;
    font-style: italic;
  }

  /* Responsive table */
  @media (max-width: 768px) {
    .article-content :global(table) {
      font-size: 0.78rem;
      border-radius: 8px;
    }

    .article-content :global(th),
    .article-content :global(td) {
      padding: 10px 12px;
    }

    .article-content :global(th) {
      font-size: 0.72rem;
    }
  }

  /* FAQ section styling */
  .article-content :global(.faq-section) {
    background: var(--gris-clair);
    border-radius: 12px;
    padding: 32px;
    margin: 40px 0 24px;
  }

  .article-content :global(.faq-section h2) {
    margin-top: 0;
    font-size: 1.5rem;
  }

  .article-content :global(.faq-section h3) {
    background: var(--blanc);
    padding: 14px 18px;
    border-radius: 8px;
    margin: 20px 0 8px;
    font-size: 1.05rem;
    border-left: 3px solid var(--orange);
  }

  .article-content :global(.faq-section p) {
    padding-left: 18px;
    margin-bottom: 12px;
  }

  /* Cluster box (lien vers la page pilier) */
  .article-content :global(.cluster-box) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin: 40px 0 24px;
    padding: 24px 28px;
    background: rgba(255, 107, 53, 0.06);
    border: 1px solid rgba(255, 107, 53, 0.2);
    border-radius: 12px;
  }

  .article-content :global(.cluster-box p) {
    margin: 0;
    font-size: 1rem;
  }

  .article-content :global(.cluster-box-link) {
    display: inline-flex;
    align-items: center;
    padding: 10px 20px;
    background: var(--orange);
    color: #fff !important;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none !important;
    white-space: nowrap;
    transition: background 0.2s;
  }

  .article-content :global(.cluster-box-link:hover) {
    background: var(--orange-dark);
  }

  .article-back {
    text-align: center;
    padding-bottom: 48px;
  }

  @media (max-width: 768px) {
    .article-header h1 {
      font-size: 1.75rem;
    }

    .article-content :global(h2) {
      font-size: 1.4rem;
    }
  }
</style>

---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHeroV2 from '../components/v2/PageHeroV2.astro';
import PricingV2 from '../components/v2/PricingV2.astro';
import DownloadV2 from '../components/v2/DownloadV2.astro';
import StickyMobileCta from '../components/v2/StickyMobileCta.astro';
import { getTranslations } from '../i18n';

const lang = 'fr';
const t = getTranslations(lang);
---

<Layout title={`${t.pricing.title} - SAPIRO`} description={t.pricing.metaDescription} lang={lang}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "SAPIRO",
      "applicationCategory": "EducationalApplication",
      "operatingSystem": "iOS, Android",
      "offers": [
        { "@type": "Offer", "price": "0", "priceCurrency": "EUR", "description": "Version gratuite" },
        { "@type": "Offer", "price": "1.99", "priceCurrency": "EUR", "description": "Sapiro+ Mensuel", "priceValidUntil": "2027-12-31" },
        { "@type": "Offer", "price": "19.99", "priceCurrency": "EUR", "description": "Sapiro+ Annuel", "priceValidUntil": "2027-12-31" },
        { "@type": "Offer", "price": "39.99", "priceCurrency": "EUR", "description": "Sapiro+ À vie", "priceValidUntil": "2027-12-31" }
      ],
      "description": "Quiz de culture générale : géographie, histoire, art et nature. 2000+ questions pour apprendre en s'amusant.",
      "screenshot": "https://sapiro.app/images/icon-1024.png",
      "url": "https://sapiro.app/pricing/"
    })} />
  </Fragment>
  <Header lang={lang} t={t} />

  <main class="page-main">
    <PageHeroV2
      lang={lang}
      kicker="💎 Tarifs"
      title="Gratuit, ou"
      highlight="très abordable"
      subtitle={t.pricing.intro}
      backLabel={t.header.home}
    />

    <PricingV2 lang={lang} />

    <DownloadV2 lang={lang} />
  </main>

  <Footer lang={lang} t={t} />
  <StickyMobileCta lang={lang} />
</Layout>

<style is:global>
  .page-main > section {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1), transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .page-main > section.revealed,
  .page-main > section:first-child {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .page-main > section {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

<script is:inline>
(() => {
  const sections = document.querySelectorAll('.page-main > section');
  if (!('IntersectionObserver' in window)) {
    sections.forEach((s) => s.classList.add('revealed'));
    return;
  }
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        e.target.classList.add('revealed');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  sections.forEach((s) => io.observe(s));
})();
</script>

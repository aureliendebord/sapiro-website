---
import type { Lang } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const copy = {
  fr: {
    badge: 'Nouveau • Nature est là 🦁',
    titleA: 'Deviens',
    titleHighlight: 'incollable',
    titleB: 'en culture générale.',
    subtitle: 'Géographie, histoire, art, nature. 2 000+ questions vérifiées. Sans pub, sans data, hors ligne.',
    ctaPrimary: 'Télécharger gratuitement',
    ctaSecondary: 'Essayer un quiz',
    proofQuestions: '2 000+',
    proofQuestionsLabel: 'questions vérifiées',
    proofPrice: 'Gratuit',
    proofPriceLabel: 'Zéro pub, zéro data',
  },
  en: {
    badge: 'New • Nature is here 🦁',
    titleA: 'Become',
    titleHighlight: 'unbeatable',
    titleB: 'at general knowledge.',
    subtitle: 'Geography, history, art, nature. 2,000+ verified questions. No ads, no data, offline.',
    ctaPrimary: 'Download for free',
    ctaSecondary: 'Try a quiz',
    proofQuestions: '2,000+',
    proofQuestionsLabel: 'verified questions',
    proofPrice: 'Free',
    proofPriceLabel: 'Zero ads, zero data',
  },
  es: {
    badge: 'Nuevo • Naturaleza ya está aquí 🦁',
    titleA: 'Hazte',
    titleHighlight: 'imbatible',
    titleB: 'en cultura general.',
    subtitle: 'Geografia, historia, arte, naturaleza. 2 000+ preguntas verificadas. Sin anuncios, sin datos, sin conexion.',
    ctaPrimary: 'Descargar gratis',
    ctaSecondary: 'Probar un quiz',
    proofQuestions: '2 000+',
    proofQuestionsLabel: 'preguntas verificadas',
    proofPrice: 'Gratis',
    proofPriceLabel: 'Cero anuncios, cero datos',
  },
};

const t = copy[lang];
---

<section class="hero-v2">
  <div class="bg-mesh" aria-hidden="true"></div>
  <div class="bg-grid" aria-hidden="true"></div>

  <div class="container hero-inner">
    <div class="hero-left">
      <div class="badge">
        <span class="badge-dot"></span>
        <span>{t.badge}</span>
      </div>

      <h1 class="title">
        {t.titleA}<br />
        <span class="highlight">
          {t.titleHighlight}
          <svg class="underline" viewBox="0 0 300 14" preserveAspectRatio="none" aria-hidden="true">
            <path d="M2 9 Q 80 2, 150 7 T 298 6" stroke="currentColor" stroke-width="4" fill="none" stroke-linecap="round"/>
          </svg>
        </span><br />
        {t.titleB}
      </h1>

      <p class="subtitle">{t.subtitle}</p>

      <div class="ctas">
        <a href="#download" class="cta-primary">
          <span>{t.ctaPrimary}</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="#demo-quiz" class="cta-secondary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          <span>{t.ctaSecondary}</span>
        </a>
      </div>

      <div class="proof-row">
        <div class="proof-item">
          <div class="proof-icon">✅</div>
          <div class="proof-text">
            <strong>{t.proofQuestions}</strong>
            <span>{t.proofQuestionsLabel}</span>
          </div>
        </div>
        <div class="proof-divider" aria-hidden="true"></div>
        <div class="proof-item">
          <div class="proof-icon">🎁</div>
          <div class="proof-text">
            <strong>{t.proofPrice}</strong>
            <span>{t.proofPriceLabel}</span>
          </div>
        </div>
      </div>
    </div>

    <div class="hero-right">
      <div class="phone-stage">
        <div class="glow glow-1"></div>
        <div class="glow glow-2"></div>

        <div class="orbit" aria-hidden="true">
          <span class="orbit-emoji" style="--a:0deg; --r:180px">🇫🇷</span>
          <span class="orbit-emoji" style="--a:60deg; --r:190px">🗿</span>
          <span class="orbit-emoji" style="--a:120deg; --r:175px">🎨</span>
          <span class="orbit-emoji" style="--a:180deg; --r:195px">🦁</span>
          <span class="orbit-emoji" style="--a:240deg; --r:180px">🇯🇵</span>
          <span class="orbit-emoji" style="--a:300deg; --r:185px">🏛️</span>
        </div>

        <div class="phone-tilt">
          <div class="phone">
            <div class="phone-notch"></div>
            <div class="phone-screen">
              <img src={`/images/screenshots/${lang}/01.png`} alt="Quiz SAPIRO" class="slide slide-1" loading="eager" />
              <img src={`/images/screenshots/${lang}/02.png`} alt="Quiz SAPIRO" class="slide slide-2" loading="eager" />
              <img src={`/images/screenshots/${lang}/05.png`} alt="Quiz SAPIRO" class="slide slide-3" loading="eager" />
            </div>
          </div>
        </div>

        <div class="floating-card card-top">
          <div class="card-emoji">⚡</div>
          <div class="card-content">
            <div class="card-num">+120 XP</div>
            <div class="card-label">Série de 5</div>
          </div>
        </div>

        <div class="floating-card card-bottom">
          <div class="card-emoji">🏆</div>
          <div class="card-content">
            <div class="card-num">Badge débloqué</div>
            <div class="card-label">Explorateur</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-v2 {
    position: relative;
    overflow: hidden;
    padding: 120px 0 80px;
    background: #0a0a0f;
    color: #fff;
    isolation: isolate;
  }

  .bg-mesh {
    position: absolute;
    inset: -10%;
    z-index: -2;
    background:
      radial-gradient(600px circle at 15% 20%, rgba(255, 107, 53, 0.55), transparent 55%),
      radial-gradient(700px circle at 85% 30%, rgba(168, 85, 247, 0.45), transparent 55%),
      radial-gradient(500px circle at 60% 90%, rgba(251, 191, 36, 0.35), transparent 55%),
      radial-gradient(400px circle at 10% 100%, rgba(20, 184, 166, 0.35), transparent 55%);
    filter: blur(20px);
    animation: meshDrift 18s ease-in-out infinite alternate;
  }

  @keyframes meshDrift {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(-3%, 2%) scale(1.05); }
  }

  .bg-grid {
    position: absolute;
    inset: 0;
    z-index: -1;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 64px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  /* Badge */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.02em;
    margin-bottom: 28px;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 12px rgba(34, 197, 94, 0.8);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  /* Title */
  .title {
    font-size: clamp(2.8rem, 6.5vw, 5.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.02;
    margin-bottom: 28px;
  }

  .highlight {
    position: relative;
    display: inline-block;
    background: linear-gradient(135deg, #ff6b35 0%, #fbbf24 50%, #ff6b35 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: gradientShift 4s ease-in-out infinite;
    padding-right: 6px;
  }

  @keyframes gradientShift {
    0%, 100% { background-position: 0% center; }
    50% { background-position: 100% center; }
  }

  .underline {
    position: absolute;
    left: 0;
    bottom: -10px;
    width: 100%;
    height: 14px;
    color: #ff6b35;
    opacity: 0.9;
  }

  .subtitle {
    font-size: clamp(1.05rem, 1.5vw, 1.25rem);
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.6;
    max-width: 540px;
    margin-bottom: 36px;
  }

  /* CTAs */
  .ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 28px;
    background: linear-gradient(135deg, #ff6b35 0%, #ff8f5c 100%);
    color: #fff;
    border-radius: 14px;
    font-weight: 600;
    font-size: 16px;
    box-shadow: 0 10px 30px -8px rgba(255, 107, 53, 0.6), inset 0 1px 0 rgba(255, 255, 255, 0.2);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 40px -8px rgba(255, 107, 53, 0.7), inset 0 1px 0 rgba(255, 255, 255, 0.25);
  }

  .cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 24px;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #fff;
    border-radius: 14px;
    font-weight: 600;
    font-size: 15px;
    transition: background 0.2s;
  }

  .cta-secondary:hover {
    background: rgba(255, 255, 255, 0.14);
  }

  .cta-secondary svg {
    color: #ff6b35;
  }

  /* Proof row */
  .proof-row {
    display: inline-flex;
    align-items: center;
    gap: 20px;
    padding: 14px 20px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
  }

  .proof-item {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .proof-icon { font-size: 22px; }

  .proof-text { display: flex; flex-direction: column; }
  .proof-text strong { font-size: 14px; font-weight: 700; }
  .proof-text span { font-size: 12px; color: rgba(255, 255, 255, 0.55); }

  .proof-divider {
    width: 1px;
    height: 36px;
    background: rgba(255, 255, 255, 0.1);
  }

  /* Phone stage */
  .hero-right { display: flex; justify-content: center; align-items: center; }

  .phone-stage {
    position: relative;
    width: 420px;
    height: 560px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
  }

  .glow-1 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(255, 107, 53, 0.6), transparent 70%);
    top: 10%;
    left: 5%;
    animation: glowFloat 6s ease-in-out infinite;
  }

  .glow-2 {
    width: 280px;
    height: 280px;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.5), transparent 70%);
    bottom: 10%;
    right: 5%;
    animation: glowFloat 7s ease-in-out infinite 1s;
  }

  @keyframes glowFloat {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(20px, -15px); }
  }

  /* Orbit */
  .orbit {
    position: absolute;
    inset: 0;
    animation: orbitRotate 30s linear infinite;
  }

  .orbit-emoji {
    position: absolute;
    top: 50%;
    left: 50%;
    font-size: 32px;
    transform: translate(-50%, -50%) rotate(var(--a)) translateY(calc(var(--r) * -1)) rotate(calc(var(--a) * -1));
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.4));
    animation: orbitBob 3s ease-in-out infinite;
  }

  @keyframes orbitRotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes orbitBob {
    0%, 100% { scale: 1; }
    50% { scale: 1.15; }
  }

  /* Phone */
  .phone-tilt {
    transform: perspective(1400px) rotateY(-14deg) rotateX(6deg) rotateZ(-2deg);
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    filter: drop-shadow(0 40px 60px rgba(0, 0, 0, 0.5));
  }

  .phone-stage:hover .phone-tilt {
    transform: perspective(1400px) rotateY(-8deg) rotateX(3deg) rotateZ(-1deg);
  }

  .phone {
    position: relative;
    width: 280px;
    height: 570px;
    background: #0a0a0a;
    border-radius: 48px;
    padding: 10px;
    border: 2px solid #1f1f1f;
    box-shadow:
      inset 0 0 0 2px rgba(255, 255, 255, 0.05),
      0 0 0 8px rgba(255, 255, 255, 0.03);
  }

  .phone-notch {
    position: absolute;
    top: 14px;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 28px;
    background: #000;
    border-radius: 999px;
    z-index: 2;
  }

  .phone-screen {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 38px;
    overflow: hidden;
    background: #000;
  }

  .slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    animation: slideShow 12s ease-in-out infinite;
  }

  .slide-1 { opacity: 1; animation-delay: 0s; }
  .slide-2 { animation-delay: 4s; }
  .slide-3 { animation-delay: 8s; }

  @keyframes slideShow {
    0%, 28% { opacity: 1; transform: scale(1); }
    35%, 95% { opacity: 0; transform: scale(1.02); }
    100% { opacity: 1; transform: scale(1); }
  }

  /* Floating cards */
  .floating-card {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    background: rgba(255, 255, 255, 0.98);
    color: #1f2937;
    border-radius: 14px;
    box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.4);
    z-index: 3;
  }

  .card-top {
    top: 12%;
    right: -10px;
    animation: floatCard 4s ease-in-out infinite;
  }

  .card-bottom {
    bottom: 18%;
    left: -30px;
    animation: floatCard 4s ease-in-out infinite 2s;
  }

  @keyframes floatCard {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .card-emoji { font-size: 22px; }
  .card-num { font-size: 14px; font-weight: 700; }
  .card-label { font-size: 11px; color: #6b7280; }

  /* Responsive */
  @media (max-width: 968px) {
    .hero-v2 { padding: 96px 0 60px; }
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 48px;
      text-align: center;
    }
    .subtitle { margin-left: auto; margin-right: auto; }
    .ctas, .proof-row, .badge { justify-content: center; }
    .proof-row { display: inline-flex; }
    .phone-stage { width: 340px; height: 480px; }
    .phone { width: 240px; height: 490px; }
    .card-top { right: -30px; }
    .card-bottom { left: -40px; }
  }

  @media (max-width: 520px) {
    .hero-v2 { padding: 80px 0 48px; }
    .ctas { flex-direction: column; align-items: stretch; }
    .cta-primary, .cta-secondary { justify-content: center; }
    .proof-row { flex-direction: column; gap: 12px; align-items: flex-start; }
    .proof-divider { width: 100%; height: 1px; }
    .phone-stage { width: 280px; height: 420px; }
    .phone { width: 210px; height: 430px; border-radius: 38px; }
    .phone-notch { width: 80px; height: 22px; }
    .phone-screen { border-radius: 30px; }
    .orbit-emoji { font-size: 24px; }
    .card-top, .card-bottom { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .bg-mesh, .badge-dot, .highlight, .glow-1, .glow-2, .orbit, .orbit-emoji, .slide, .card-top, .card-bottom {
      animation: none !important;
    }
  }
</style>

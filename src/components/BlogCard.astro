---
import type { Lang } from '../i18n';
import { getLocalePath, getTranslations } from '../i18n';

interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  category: string;
  readingTime?: number;
  lang: Lang;
}

const { title, description, date, slug, category, readingTime, lang } = Astro.props;
const t = getTranslations(lang);
const href = getLocalePath(`/blog/${slug}`, lang);

const formattedDate = date.toLocaleDateString(lang === 'fr' ? 'fr-FR' : lang === 'en' ? 'en-US' : 'es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const categoryLabel = t.blog.categories[category] || category;
---

<a href={href} class="blog-card">
  <div class="blog-card-content">
    <div class="blog-card-meta">
      <span class="blog-card-category">{categoryLabel}</span>
      {readingTime && <span class="blog-card-reading">{readingTime} {t.blog.readingTime}</span>}
    </div>
    <h3 class="blog-card-title">{title}</h3>
    <p class="blog-card-description">{description}</p>
    <div class="blog-card-footer">
      <time datetime={date.toISOString()}>{formattedDate}</time>
      <span class="blog-card-link">{t.blog.readMore} &rarr;</span>
    </div>
  </div>
</a>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    background: var(--blanc);
    border-radius: var(--border-radius);
    box-shadow: var(--shadow);
    transition: transform 0.2s, box-shadow 0.2s;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .blog-card-content {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .blog-card-category {
    display: inline-block;
    padding: 4px 12px;
    background: rgba(255, 107, 53, 0.1);
    color: var(--orange);
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
  }

  .blog-card-reading {
    font-size: 13px;
    color: var(--gris);
  }

  .blog-card-title {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 8px;
    color: var(--noir);
  }

  .blog-card-description {
    font-size: 0.95rem;
    color: var(--gris);
    line-height: 1.6;
    flex: 1;
    margin-bottom: 16px;
  }

  .blog-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 16px;
    border-top: 1px solid var(--gris-clair);
  }

  .blog-card-footer time {
    font-size: 13px;
    color: var(--gris);
  }

  .blog-card-link {
    font-size: 14px;
    font-weight: 600;
    color: var(--orange);
    transition: gap 0.2s;
  }

  .blog-card:hover .blog-card-link {
    text-decoration: underline;
  }
</style>

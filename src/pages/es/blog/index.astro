---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import PageHeroV2 from '../../../components/v2/PageHeroV2.astro';
import DownloadV2 from '../../../components/v2/DownloadV2.astro';
import StickyMobileCta from '../../../components/v2/StickyMobileCta.astro';
import { getTranslations } from '../../../i18n';
import { clusters } from '../../../data/clusters';

const lang = 'es';
const t = getTranslations(lang);

const allPosts = (await getCollection('blog', ({ data }) => data.lang === 'es'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const clusterCards = clusters.map((c) => ({
  label: c.label[lang],
  tagline: c.tagline[lang],
  icon: c.icon,
  href: c.pillarSlug[lang],
  count: allPosts.filter((p) => c.categories.includes(p.data.category)).length,
}));

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: t.blog.title,
  description: t.blog.subtitle,
  url: 'https://sapiro.app/es/blog/',
  publisher: {
    '@type': 'Organization',
    name: 'SAPIRO',
    logo: { '@type': 'ImageObject', url: 'https://sapiro.app/images/icon-1024.png' },
  },
  blogPost: allPosts.map((post) => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.date.toISOString(),
    url: `https://sapiro.app/es/blog/${post.data.urlSlug}/`,
    author: { '@type': 'Person', name: post.data.author },
  })),
};
---

<Layout title={`${t.blog.title} | SAPIRO`} description={t.blog.subtitle} lang={lang}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
  </Fragment>
  <Header lang={lang} t={t} />

  <main class="page-main">
    <PageHeroV2
      lang={lang}
      kicker="✍️ Blog"
      title="Aprender, jugar,"
      highlight="entender."
      subtitle={t.blog.subtitle}
      backLabel={t.header.home}
    />

    <section class="cluster-hub">
      <div class="container">
        <h2 class="section-title">{t.blog.exploreByTheme}</h2>
        <div class="cluster-grid">
          {clusterCards.map((c) => (
            <a href={c.href} class="cluster-card">
              <span class="cluster-icon">{c.icon}</span>
              <span class="cluster-label">{c.label}</span>
              <span class="cluster-tagline">{c.tagline}</span>
              <span class="cluster-count">{c.count} {t.blog.articlesWord}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <DownloadV2 lang={lang} />
  </main>

  <Footer lang={lang} t={t} />
  <StickyMobileCta lang={lang} />
</Layout>

<style>
  .section-title { font-size: clamp(1.5rem, 3vw, 2rem); text-align: center; margin-bottom: 32px; }
  .cluster-hub { padding: 56px 0 80px; background: #fff; }
  .cluster-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .cluster-card { display: flex; flex-direction: column; gap: 6px; padding: 24px 20px; border: 1.5px solid #e5e7eb; border-radius: 16px; background: #fff; transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s; }
  .cluster-card:hover { border-color: var(--orange); transform: translateY(-3px); box-shadow: 0 12px 28px -10px rgba(255, 107, 53, 0.35); }
  .cluster-icon { font-size: 1.75rem; }
  .cluster-label { font-weight: 700; font-size: 1.1rem; color: var(--noir); }
  .cluster-tagline { font-size: 0.85rem; color: var(--gris); line-height: 1.5; flex-grow: 1; }
  .cluster-count { font-size: 0.78rem; font-weight: 700; color: var(--orange); text-transform: uppercase; letter-spacing: 0.03em; }
  @media (max-width: 1024px) { .cluster-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .cluster-grid { grid-template-columns: 1fr; } .cluster-hub { padding: 40px 0 64px; } }
  .page-main > section { opacity: 0; transform: translateY(24px); transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1), transform 0.7s cubic-bezier(0.22, 1, 0.36, 1); }
  .page-main > section.revealed, .page-main > section:first-child { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) { .page-main > section { opacity: 1 !important; transform: none !important; transition: none !important; } }
</style>

<script is:inline>
(() => {
  const sections = document.querySelectorAll('.page-main > section');
  if (!('IntersectionObserver' in window)) { sections.forEach((s) => s.classList.add('revealed')); return; }
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('revealed'); io.unobserve(e.target); } });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  sections.forEach((s) => io.observe(s));
})();
</script>

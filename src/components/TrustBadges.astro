---
import type { Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const content = {
  fr: {
    items: [
      {
        emoji: "⭐",
        text: "Note 5/5 sur l'App Store et Google Play"
      },
      {
        emoji: "🏅",
        text: "Recommandé par les enseignants — Programme Google Play"
      },
      {
        emoji: "🔒",
        text: "Aucune donnée collectée — 100% adapté aux enfants"
      }
    ]
  },
  en: {
    items: [
      {
        emoji: "⭐",
        text: "Rated 5/5 on App Store and Google Play"
      },
      {
        emoji: "🏅",
        text: "Teacher Approved — Google Play program"
      },
      {
        emoji: "🔒",
        text: "No data collected — 100% child-safe"
      }
    ]
  },
  es: {
    items: [
      {
        emoji: "⭐",
        text: "Nota 5/5 en App Store y Google Play"
      },
      {
        emoji: "🏅",
        text: "Recomendado por profesores — Programa Google Play"
      },
      {
        emoji: "🔒",
        text: "Sin recopilación de datos — 100% seguro para niños"
      }
    ]
  }
};

const t = content[lang];
---

<section class="trust-badges">
  <div class="container">
    <div class="trust-grid">
      {t.items.map((item) => (
        <div class="trust-item">
          <span class="trust-emoji">{item.emoji}</span>
          <span class="trust-text">{item.text}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .trust-badges {
    background: var(--blanc);
    padding: 48px 0;
    border-top: 1px solid var(--gris-clair);
    border-bottom: 1px solid var(--gris-clair);
  }

  .trust-grid {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 48px;
    flex-wrap: wrap;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .trust-emoji {
    font-size: 1.75rem;
    flex-shrink: 0;
  }

  .trust-text {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--noir);
    line-height: 1.4;
  }

  @media (max-width: 968px) {
    .trust-grid {
      flex-direction: column;
      gap: 24px;
      align-items: flex-start;
      max-width: 400px;
      margin: 0 auto;
    }
  }
</style>

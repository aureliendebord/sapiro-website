---
interface Props {
  t: any;
}

const { t } = Astro.props;
---

<section class="about section">
  <div class="container">
    <h2>{t.about.title}</h2>
    <p class="about-text">{t.about.text}</p>
    <div class="about-stats">
      <div class="about-stat">
        <span class="about-stat-value">{t.about.stats.questions}</span>
      </div>
      <div class="about-stat">
        <span class="about-stat-value">{t.about.stats.countries}</span>
      </div>
      <div class="about-stat">
        <span class="about-stat-value">{t.about.stats.artworks}</span>
      </div>
      <div class="about-stat">
        <span class="about-stat-value">{t.about.stats.species}</span>
      </div>
      <div class="about-stat">
        <span class="about-stat-value">{t.about.stats.rating}</span>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    background: var(--gris-clair);
  }

  .about h2 {
    text-align: center;
    margin-bottom: 24px;
  }

  .about-text {
    max-width: 720px;
    margin: 0 auto 40px;
    text-align: center;
    color: var(--gris);
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .about-stats {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .about-stat {
    background: var(--blanc);
    border-radius: 12px;
    padding: 16px 24px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .about-stat-value {
    font-weight: 700;
    color: var(--orange);
    font-size: 0.95rem;
  }

  @media (max-width: 768px) {
    .about-stats {
      gap: 10px;
    }

    .about-stat {
      padding: 12px 16px;
    }
  }
</style>

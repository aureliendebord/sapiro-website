---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getTranslations, languages } from '../i18n';

// Le 404.html est pré-généré en FR. La langue affichée est ensuite
// basculée côté client (script en bas) selon le path /en/ ou /es/.
// Astro.request.headers est vide au build : pas de détection serveur possible.
const lang = 'fr';
const t = getTranslations(lang);

// Embarque les 3 traductions pour le switch côté client.
const i18nNotFound = {
  fr: languages.fr.notFound,
  en: languages.en.notFound,
  es: languages.es.notFound,
};

// Status 404 utile uniquement quand la page est servie via le worker SSR.
// Pour le 404.html statique, c'est Cloudflare Pages qui force le status.
Astro.response.status = 404;
Astro.response.statusText = 'Not Found';
Astro.response.headers.set('X-Robots-Tag', 'noindex');
---

<Layout
  title={t.notFound.title}
  description={t.notFound.intro}
  lang={lang}
  noDefaultHreflang={true}
  noCanonical={true}
>
  <Fragment slot="head">
    <meta name="robots" content="noindex,follow" />
  </Fragment>

  <Header lang={lang} t={t} />

  <main class="not-found">
    <div class="not-found-inner">
      <p class="not-found-code">404</p>
      <h1 class="not-found-title" data-i18n="heading">{t.notFound.heading}</h1>
      <p class="not-found-intro" data-i18n="intro">{t.notFound.intro}</p>
      <div class="not-found-actions">
        <a href="/" class="btn btn-orange" data-i18n="backHome" data-href-prefix="">{t.notFound.backHome}</a>
        <a href="/blog/" class="btn btn-secondary" data-i18n="backBlog" data-href-prefix="/blog/">{t.notFound.backBlog}</a>
      </div>
    </div>
  </main>

  <Footer lang={lang} t={t} />

  <script type="application/json" id="i18n-404" set:html={JSON.stringify(i18nNotFound)} />
  <script>
    (function () {
      const data = document.getElementById('i18n-404');
      if (!data) return;
      const dict = JSON.parse(data.textContent || '{}');

      // Détection langue : path > referrer > navigator.language > fr
      function detectLang() {
        const path = location.pathname;
        if (path.startsWith('/en/')) return 'en';
        if (path.startsWith('/es/')) return 'es';
        const ref = document.referrer || '';
        if (ref.includes('/en/')) return 'en';
        if (ref.includes('/es/')) return 'es';
        const nav = (navigator.language || '').toLowerCase();
        if (nav.startsWith('en')) return 'en';
        if (nav.startsWith('es')) return 'es';
        return 'fr';
      }

      const lang = detectLang();
      if (lang === 'fr' || !dict[lang]) return;

      const t = dict[lang];
      document.documentElement.lang = lang;
      if (t.title) document.title = t.title;

      document.querySelectorAll('[data-i18n]').forEach((el) => {
        const key = el.getAttribute('data-i18n');
        if (key && t[key]) el.textContent = t[key];
      });

      // Re-préfixe les liens d'action selon la langue cible
      document.querySelectorAll('[data-href-prefix]').forEach((el) => {
        const suffix = el.getAttribute('data-href-prefix') || '';
        el.setAttribute('href', `/${lang}${suffix || '/'}`);
      });
    })();
  </script>
</Layout>

<style>
  .not-found {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 1.5rem;
  }
  .not-found-inner {
    max-width: 640px;
    text-align: center;
  }
  .not-found-code {
    font-size: 5rem;
    font-weight: 800;
    line-height: 1;
    margin: 0 0 1rem;
    color: var(--orange);
    letter-spacing: -0.04em;
  }
  .not-found-title {
    font-size: 2rem;
    margin: 0 0 1rem;
    color: var(--noir);
  }
  .not-found-intro {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--gris);
    margin: 0 0 2rem;
  }
  .not-found-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>

---
interface Section {
  title: string;
  content: string;
}

interface Props {
  intro: string;
  lastUpdate: string;
  lastUpdateDate: string;
  sections: Section[];
}

const { intro, lastUpdate, lastUpdateDate, sections } = Astro.props;
---

<section class="legal">
  <div class="container">
    <div class="wrap">
      <p class="last-update">
        <span class="dot" aria-hidden="true"></span>
        {lastUpdate} : <strong>{lastUpdateDate}</strong>
      </p>

      <p class="intro">{intro}</p>

      <div class="sections">
        {sections.map((section, i) => (
          <article class="section">
            <div class="section-num">{String(i + 1).padStart(2, '0')}</div>
            <div class="section-body">
              <h2>{section.title}</h2>
              <div class="content" set:html={section.content}></div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .legal {
    background: #fff;
    padding: 72px 0 96px;
  }

  .wrap {
    max-width: 820px;
    margin: 0 auto;
  }

  .last-update {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 14px;
    background: #f3f4f6;
    color: #4b5563;
    border-radius: 999px;
    font-size: 13px;
    margin-bottom: 32px;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 8px rgba(34, 197, 94, 0.5);
  }

  .last-update strong {
    color: #0a0a0f;
    font-weight: 600;
  }

  .intro {
    font-size: 1.15rem;
    line-height: 1.7;
    color: #374151;
    padding: 20px 24px;
    background: linear-gradient(135deg, rgba(255, 107, 53, 0.08), rgba(251, 191, 36, 0.08));
    border-left: 3px solid #ff6b35;
    border-radius: 0 12px 12px 0;
    margin-bottom: 48px;
  }

  .sections {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .section {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 20px;
    padding: 24px 0;
    border-bottom: 1px solid #f3f4f6;
  }

  .section:last-child {
    border-bottom: none;
  }

  .section-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, #ff6b35, #fbbf24);
    color: #fff;
    border-radius: 14px;
    font-size: 15px;
    font-weight: 800;
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }

  .section-body h2 {
    font-size: 1.35rem;
    font-weight: 700;
    color: #0a0a0f;
    letter-spacing: -0.01em;
    margin-bottom: 10px;
  }

  .content,
  .content p {
    font-size: 15px;
    color: #4b5563;
    line-height: 1.7;
  }

  .content :global(p) { margin-bottom: 12px; }
  .content :global(p:last-child) { margin-bottom: 0; }
  .content :global(h3) {
    font-size: 14px;
    font-weight: 700;
    color: #0a0a0f;
    margin: 16px 0 8px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .content :global(ul) { padding-left: 20px; margin-bottom: 12px; }
  .content :global(li) { margin-bottom: 6px; }
  .content :global(strong) { color: #0a0a0f; font-weight: 600; }

  @media (max-width: 640px) {
    .legal { padding: 56px 0 72px; }
    .section {
      grid-template-columns: 40px 1fr;
      gap: 14px;
    }
    .section-num {
      width: 36px;
      height: 36px;
      font-size: 13px;
      border-radius: 10px;
    }
    .section-body h2 { font-size: 1.15rem; }
    .intro { font-size: 1rem; padding: 16px 18px; }
  }
</style>

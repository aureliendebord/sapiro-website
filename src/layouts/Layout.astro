---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang?: string;
}

const { title, description, lang = 'fr' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL('/images/icon-1024.png', Astro.site);
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="author" content="SAPIRO" />

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="180x180" href="/images/icon-180.png" />
  <link rel="apple-touch-icon" href="/images/icon-180.png" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageURL.toString()} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL.toString()} />

  <!-- Canonical -->
  <link rel="canonical" href={canonicalURL} />

  <!-- Alternate languages -->
  <link rel="alternate" hreflang="fr" href="https://sapiro.app/" />
  <link rel="alternate" hreflang="en" href="https://sapiro.app/en/" />
  <link rel="alternate" hreflang="es" href="https://sapiro.app/es/" />
  <link rel="alternate" hreflang="x-default" href="https://sapiro.app/" />

  <title>{title}</title>
  <slot name="head" />
</head>
<body>
  <slot />
</body>
</html>

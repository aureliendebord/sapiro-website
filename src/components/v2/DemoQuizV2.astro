const totalQuestions = 3;
---

<section class="demo-quiz" id="demo-quiz">
  <div class="container">
    <div class="header-block">
      <span class="kicker"><img src="/images/icons/lightning.webp" class="app-ico" alt="" aria-hidden="true" /> {t.kicker}</span>
      <h2 class="title">{t.title}</h2>
      <p class="subtitle">{t.subtitle}</p>
    </div>

    <div
      class="quiz-card"
      id="quiz-card"
      data-lang={lang}
      data-themes={JSON.stringify(themesList)}
      data-i18n={JSON.stringify({
        question: t.question,
        explanation: t.explanation,
        next: t.next,
        finish: t.finish,
        correct: t.correct,
        wrong: t.wrong,
        score: t.score,
        resultPerfect: t.resultPerfect,
        resultGood: t.resultGood,
        resultMeh: t.resultMeh,
      })}
    >
      <!-- Progress bar -->
      <div class="progress">
        <div class="progress-fill" id="progress-fill"></div>
      </div>

      <!-- Theme selection screen -->
      <div class="screen screen-theme active" data-screen="theme">
        <div class="theme-visual"><img src="/images/icons/target.webp" class="app-ico" alt="" aria-hidden="true" /></div>
        <h3 class="screen-title">{t.pickTheme}</h3>
        <div class="theme-picker">
          <div class="theme-dropdown" id="theme-dropdown" data-value={themesList[0].key}>
            <button
              type="button"
              class="theme-trigger"
              id="theme-trigger"
              aria-haspopup="listbox"
              aria-expanded="false"
              aria-labelledby="theme-trigger-label"
            >
              <span class="theme-trigger-emoji" id="theme-trigger-emoji"><img src={`/images/icons/${themesList[0].icon}.webp`} class="app-ico" alt="" aria-hidden="true" /></span>
              <span class="theme-trigger-label" id="theme-trigger-label">{themesList[0].label}</span>
              <svg class="theme-trigger-chevron" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <ul class="theme-options" id="theme-options" role="listbox" aria-label={t.pickTheme}>
              {themesList.map((theme, idx) => (
                <li
                  class={`theme-option ${idx === 0 ? 'is-selected' : ''}`}
                  role="option"
                  data-value={theme.key}
                  aria-selected={idx === 0 ? 'true' : 'false'}
                  tabindex="-1"
                >
                  <span class="theme-option-emoji"><img src={`/images/icons/${theme.icon}.webp`} class="app-ico" alt="" aria-hidden="true" /></span>
                  <span class="theme-option-label">{theme.label}</span>
                  <svg class="theme-option-check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <!-- Question template (3 screens, filled dynamically) -->
      {[0, 1, 2].map((idx) => (
        <div class="screen screen-question" data-screen={`q-${idx}`}>
          <div class="question-meta">
            <span class="question-num">{t.question} {idx + 1}/{totalQuestions}</span>
            <span class="question-theme-tag" data-q-theme-tag={idx}></span>
          </div>
          <div class="question-visual" data-q-visual={idx}>
            <img class="q-image" data-q-image={idx} src="" alt="" />
          </div>
          <h3 class="screen-title" data-q-prompt={idx}></h3>
          <div class="options" data-q-options={idx}>
            {[0, 1, 2, 3].map((optIdx) => (
              <button class="option" data-option={optIdx}>
                <span class="option-letter">{String.fromCharCode(65 + optIdx)}</span>
                <span class="option-text" data-q-opt={`${idx}-${optIdx}`}></span>
              </button>
            ))}
          </div>
          <div class="feedback" data-feedback={`f-${idx}`}>
            <div class="feedback-head">
              <span class="feedback-emoji"></span>
              <span class="feedback-label"></span>
            </div>
            <p class="feedback-explanation"><strong>{t.explanation} :</strong> <span data-q-explanation={idx}></span></p>
            <button class="btn-quiz btn-quiz-primary" data-action="next" data-next={idx + 1}>
              <span data-next-label={idx}>{idx === totalQuestions - 1 ? t.finish : t.next}</span>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
        </div>
      ))}

      <!-- Result screen -->
      <div class="screen screen-result" data-screen="result">
        <div class="result-visual" id="result-emoji"><img src="/images/icons/trophy.webp" class="app-ico" alt="" aria-hidden="true" /></div>
        <div class="result-score">
          <span id="result-value">0</span><span class="result-of">/{totalQuestions}</span>
        </div>
        <h3 class="screen-title" id="result-message">{t.score}</h3>
        <p class="screen-sub">{t.subtitle}</p>
        <div class="result-actions">
          <button class="btn-quiz btn-quiz-ghost" data-action="restart">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
            {t.changeTheme}
          </button>
          <a href="#download" class="btn-quiz btn-quiz-primary">
            {t.download}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>

      <!-- Confetti -->
      <div class="confetti" id="confetti" aria-hidden="true"></div>
    </div>
  </div>
</section>

<script is:inline>
(() => {
  const card = document.getElementById('quiz-card');
  if (!card) return;

  const themesData = JSON.parse(card.dataset.themes || '[]');
  const i18n = JSON.parse(card.dataset.i18n || '{}');
  const screens = card.querySelectorAll('.screen');
  const progressFill = document.getElementById('progress-fill');
  const totalQuestions = 3;
  let currentTheme = null;
  let score = 0;

  const showScreen = (name) => {
    screens.forEach((s) => s.classList.toggle('active', s.dataset.screen === name));
    let step = 0;
    if (name === 'theme') step = 0;
    else if (name.startsWith('q-')) step = parseInt(name.split('-')[1]) + 1;
    else if (name === 'result') step = totalQuestions + 1;
    if (progressFill) progressFill.style.width = `${(step / (totalQuestions + 1)) * 100}%`;
  };

  const fillQuestions = (theme) => {
    theme.questions.forEach((q, idx) => {
      const img = card.querySelector(`[data-q-image="${idx}"]`);
      const visual = card.querySelector(`[data-q-visual="${idx}"]`);
      const promptEl = card.querySelector(`[data-q-prompt="${idx}"]`);
      const themeTag = card.querySelector(`[data-q-theme-tag="${idx}"]`);
      const explEl = card.querySelector(`[data-q-explanation="${idx}"]`);
      const screen = card.querySelector(`[data-screen="q-${idx}"]`);
      if (img) { img.src = q.image; img.alt = q.alt || ''; }
      if (visual) {
        visual.classList.remove('is-flag', 'is-portrait', 'is-media');
        if (q.isFlag) visual.classList.add('is-flag');
        else if (q.isPortrait) visual.classList.add('is-portrait');
        else visual.classList.add('is-media');
      }
      if (promptEl) promptEl.textContent = q.prompt;
      if (themeTag) themeTag.innerHTML = `<img src="/images/icons/${theme.icon}.webp" class="app-ico" alt="" aria-hidden="true" /> ${theme.label}`;
      if (explEl) explEl.textContent = q.explanation;
      if (screen) screen.setAttribute('data-answer', String(q.answer));
      q.options.forEach((opt, optIdx) => {
        const optTextEl = card.querySelector(`[data-q-opt="${idx}-${optIdx}"]`);
        if (optTextEl) optTextEl.textContent = opt;
      });
    });
  };

  const resetOptions = () => {
    card.querySelectorAll('.option').forEach((o) => o.classList.remove('correct', 'wrong', 'revealed'));
    card.querySelectorAll('.feedback').forEach((f) => f.classList.remove('active'));
  };

  const boomConfetti = () => {
    const host = document.getElementById('confetti');
    if (!host) return;
    host.innerHTML = '';
    const colors = ['#FF6B35', '#A855F7', '#FBBF24', '#14B8A6', '#22C55E'];
    for (let i = 0; i < 40; i++) {
      const p = document.createElement('span');
      p.className = 'confetto';
      p.style.setProperty('--c', colors[i % colors.length]);
      p.style.setProperty('--x', (Math.random() * 200 - 100) + 'px');
      p.style.setProperty('--y', -(Math.random() * 200 + 100) + 'px');
      p.style.setProperty('--r', Math.random() * 720 + 'deg');
      p.style.setProperty('--d', Math.random() * 0.3 + 's');
      host.appendChild(p);
    }
    setTimeout(() => { host.innerHTML = ''; }, 1600);
  };

  // --- Custom dropdown ---
  const dropdown = document.getElementById('theme-dropdown');
  const trigger = document.getElementById('theme-trigger');
  const optionsList = document.getElementById('theme-options');
  const triggerEmoji = document.getElementById('theme-trigger-emoji');
  const triggerLabel = document.getElementById('theme-trigger-label');

  const closeDropdown = () => {
    if (!dropdown || !trigger) return;
    dropdown.classList.remove('is-open');
    trigger.setAttribute('aria-expanded', 'false');
  };

  const openDropdown = () => {
    if (!dropdown || !trigger) return;
    dropdown.classList.add('is-open');
    trigger.setAttribute('aria-expanded', 'true');
  };

  const selectOption = (key) => {
    if (!dropdown || !optionsList) return;
    const opt = optionsList.querySelector(`[data-value="${key}"]`);
    if (!opt) return;
    dropdown.setAttribute('data-value', key);
    optionsList.querySelectorAll('.theme-option').forEach((o) => {
      const isSel = o.getAttribute('data-value') === key;
      o.classList.toggle('is-selected', isSel);
      o.setAttribute('aria-selected', isSel ? 'true' : 'false');
    });
    const emojiEl = opt.querySelector('.theme-option-emoji');
    const labelEl = opt.querySelector('.theme-option-label');
    if (triggerEmoji && emojiEl) triggerEmoji.innerHTML = emojiEl.innerHTML;
    if (triggerLabel && labelEl) triggerLabel.textContent = labelEl.textContent;
  };

  if (trigger) {
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = dropdown && dropdown.classList.contains('is-open');
      if (isOpen) closeDropdown();
      else openDropdown();
    });
  }

  const startTheme = (key) => {
    const theme = themesData.find((t) => t.key === key);
    if (!theme) return;
    currentTheme = theme;
    score = 0;
    resetOptions();
    fillQuestions(theme);
    showScreen('q-0');
  };

  if (optionsList) {
    optionsList.addEventListener('click', (e) => {
      const opt = e.target instanceof HTMLElement ? e.target.closest('[data-value]') : null;
      if (!opt) return;
      e.stopPropagation();
      const key = opt.getAttribute('data-value');
      if (!key) return;
      selectOption(key);
      closeDropdown();
      startTheme(key);
    });
  }

  // Close on click outside
  document.addEventListener('click', (e) => {
    if (!dropdown) return;
    if (!dropdown.contains(e.target)) closeDropdown();
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeDropdown();
  });

  card.addEventListener('click', (e) => {
    const target = e.target;
    if (!(target instanceof HTMLElement)) return;

    const actionEl = target.closest('[data-action]');
    if (actionEl) {
      const action = actionEl.getAttribute('data-action');
      if (action === 'next') {
        const nextIdx = parseInt(actionEl.getAttribute('data-next') || '0');
        if (nextIdx >= totalQuestions) {
          const valEl = document.getElementById('result-value');
          const msgEl = document.getElementById('result-message');
          const emojiEl = document.getElementById('result-emoji');
          if (valEl) valEl.textContent = String(score);
          if (emojiEl && msgEl) {
            const resultIcon = (name) => `<img src="/images/icons/${name}.webp" class="app-ico" alt="" aria-hidden="true" />`;
            if (score === totalQuestions) {
              emojiEl.innerHTML = resultIcon('trophy');
              msgEl.textContent = i18n.resultPerfect;
              boomConfetti();
            } else if (score >= 2) {
              emojiEl.innerHTML = resultIcon('target');
              msgEl.textContent = i18n.resultGood;
            } else {
              emojiEl.innerHTML = resultIcon('muscle');
              msgEl.textContent = i18n.resultMeh;
            }
          }
          showScreen('result');
        } else {
          showScreen('q-' + nextIdx);
        }
        return;
      }
      if (action === 'restart') {
        score = 0;
        currentTheme = null;
        resetOptions();
        showScreen('theme');
        return;
      }
    }

    const optEl = target.closest('.option');
    if (optEl && !optEl.classList.contains('revealed')) {
      const parent = optEl.closest('.screen-question');
      if (!parent) return;
      const correctIdx = parseInt(parent.getAttribute('data-answer') || '0');
      const chosen = parseInt(optEl.getAttribute('data-option') || '0');
      const options = parent.querySelectorAll('.option');
      options.forEach((o) => o.classList.add('revealed'));
      const correctOpt = options[correctIdx];
      if (correctOpt) correctOpt.classList.add('correct');
      const isRight = chosen === correctIdx;
      if (!isRight) optEl.classList.add('wrong');
      else score++;

      const screenName = parent.getAttribute('data-screen') || '';
      const idx = parseInt(screenName.split('-')[1]);
      const feedback = parent.querySelector(`[data-feedback="f-${idx}"]`);
      if (feedback) {
        const emoji = feedback.querySelector('.feedback-emoji');
        const label = feedback.querySelector('.feedback-label');
        if (emoji) emoji.innerHTML = isRight ? '<img src="/images/icons/check.webp" class="app-ico" alt="" aria-hidden="true" />' : '❌';
        if (label) label.textContent = isRight ? i18n.correct : i18n.wrong;
        feedback.classList.add('active');
      }
      if (isRight) boomConfetti();
    }
  });
})();
</script>

<style>

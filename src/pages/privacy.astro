---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getTranslations, getLocalePath } from '../i18n';

const lang = 'fr';
const t = getTranslations(lang);
const lastUpdate = '18 janvier 2025';
---

<Layout title={`${t.privacy.title} - SAPIRO`} description={t.meta.description} lang={lang}>
  <Header lang={lang} t={t} />

  <main class="privacy-page">
    <div class="container">
      <a href={getLocalePath('/', lang)} class="back-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        {t.header.home}
      </a>

      <article class="privacy-content">
        <h1>{t.privacy.title}</h1>
        <p class="last-update">{t.privacy.lastUpdate} : {lastUpdate}</p>

        <p class="intro">{t.privacy.intro}</p>

        {t.privacy.sections.map((section: any) => (
          <section class="privacy-section">
            <h2>{section.title}</h2>
            <p>{section.content}</p>
          </section>
        ))}
      </article>
    </div>
  </main>

  <Footer lang={lang} t={t} />
</Layout>

<style>
  .privacy-page {
    padding-top: 120px;
    padding-bottom: 80px;
    min-height: 100vh;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--orange);
    font-weight: 500;
    margin-bottom: 32px;
    transition: gap 0.2s;
  }

  .back-link:hover {
    gap: 12px;
  }

  .privacy-content {
    max-width: 700px;
  }

  .privacy-content h1 {
    font-size: 2.5rem;
    margin-bottom: 16px;
  }

  .last-update {
    color: var(--gris);
    margin-bottom: 32px;
  }

  .intro {
    font-size: 1.125rem;
    line-height: 1.7;
    margin-bottom: 48px;
    color: var(--noir);
  }

  .privacy-section {
    margin-bottom: 32px;
  }

  .privacy-section h2 {
    font-size: 1.25rem;
    color: var(--orange);
    margin-bottom: 12px;
  }

  .privacy-section p {
    color: var(--gris);
    line-height: 1.7;
  }
</style>

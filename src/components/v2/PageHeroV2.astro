---
import type { Lang } from '../../i18n';
import { getLocalePath } from '../../i18n';

interface Props {
  lang: Lang;
  kicker?: string;
  title: string;
  highlight?: string;
  subtitle?: string;
  backLabel?: string;
  align?: 'center' | 'left';
}

const { lang, kicker, title, highlight, subtitle, backLabel, align = 'center' } = Astro.props;
---

<section class={`page-hero align-${align}`}>
  <div class="bg-mesh" aria-hidden="true"></div>
  <div class="bg-grid" aria-hidden="true"></div>

  <div class="container inner">
    {backLabel && (
      <a href={getLocalePath('/', lang)} class="back">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        {backLabel}
      </a>
    )}

    {kicker && (
      <span class="kicker">{kicker}</span>
    )}

    <h1 class="title">
      {title}
      {highlight && (
        <>
          {' '}
          <span class="hl">
            {highlight}
            <svg class="underline" viewBox="0 0 300 14" preserveAspectRatio="none" aria-hidden="true">
              <path d="M2 9 Q 80 2, 150 7 T 298 6" stroke="currentColor" stroke-width="4" fill="none" stroke-linecap="round"/>
            </svg>
          </span>
        </>
      )}
    </h1>

    {subtitle && (
      <p class="subtitle">{subtitle}</p>
    )}

    <slot />
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    padding: 120px 0 72px;
    background: #0a0a0f;
    color: #fff;
    overflow: hidden;
    isolation: isolate;
  }

  .align-center { text-align: center; }
  .align-left { text-align: left; }

  .bg-mesh {
    position: absolute;
    inset: -10%;
    z-index: -2;
    background:
      radial-gradient(500px circle at 15% 25%, rgba(255, 107, 53, 0.4), transparent 55%),
      radial-gradient(600px circle at 85% 30%, rgba(168, 85, 247, 0.35), transparent 55%),
      radial-gradient(400px circle at 50% 90%, rgba(251, 191, 36, 0.25), transparent 55%);
    filter: blur(20px);
  }

  .bg-grid {
    position: absolute;
    inset: 0;
    z-index: -1;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
  }

  .inner {
    position: relative;
    z-index: 1;
    max-width: 820px;
  }

  .align-center .inner {
    margin: 0 auto;
  }

  .back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.75);
    font-size: 13px;
    font-weight: 500;
    margin-bottom: 24px;
    transition: all 0.2s;
  }

  .back:hover {
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    gap: 10px;
  }

  .kicker {
    display: inline-block;
    padding: 6px 14px;
    background: rgba(255, 107, 53, 0.15);
    color: #ff8f5c;
    border: 1px solid rgba(255, 107, 53, 0.3);
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin-bottom: 20px;
  }

  .title {
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-bottom: 20px;
  }

  .hl {
    position: relative;
    display: inline-block;
    background: linear-gradient(135deg, #ff6b35 0%, #fbbf24 50%, #ff6b35 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: hlShift 4s ease-in-out infinite;
    padding-right: 4px;
  }

  @keyframes hlShift {
    0%, 100% { background-position: 0% center; }
    50% { background-position: 100% center; }
  }

  .underline {
    position: absolute;
    left: 0;
    bottom: -8px;
    width: 100%;
    height: 12px;
    color: #ff6b35;
    opacity: 0.9;
  }

  .subtitle {
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.6;
    max-width: 680px;
  }

  .align-center .subtitle { margin: 0 auto; }

  @media (max-width: 768px) {
    .page-hero { padding: 100px 0 56px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hl { animation: none; }
  }
</style>

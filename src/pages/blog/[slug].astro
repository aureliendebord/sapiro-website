---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { extractFaqFromMarkdown } from '../../utils/faq';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const frPosts = allPosts.filter(p => p.data.lang === 'fr');

  return frPosts.map((post) => {
    // Find translations by translationKey
    const key = post.data.translationKey;
    const enPost = allPosts.find(p => p.data.lang === 'en' && p.data.translationKey === key);
    const esPost = allPosts.find(p => p.data.lang === 'es' && p.data.translationKey === key);

    return {
      params: { slug: post.data.urlSlug },
      props: {
        post,
        translationSlugs: {
          fr: post.data.urlSlug,
          en: enPost?.data.urlSlug || post.data.urlSlug,
          es: esPost?.data.urlSlug || post.data.urlSlug,
        },
      },
    };
  });
}

const { post, translationSlugs } = Astro.props;
const { Content } = await render(post);
const faqItems = extractFaqFromMarkdown(post.body || '');
---

<BlogPost
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  lang={post.data.lang}
  slug={post.data.urlSlug}
  category={post.data.category}
  author={post.data.author}
  readingTime={post.data.readingTime}
  faqItems={faqItems}
  translationSlugs={translationSlugs}
>
  <Content />
</BlogPost>
